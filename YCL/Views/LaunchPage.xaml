<UserControl x:Class="YCL.Views.LaunchPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
      mc:Ignorable="d"
      d:DesignHeight="640" d:DesignWidth="1040"
      Background="Transparent">
    <UserControl.Resources>
        <!-- 启动按钮样式：主题色背景，圆角 12，hover 时缩放+阴影 -->
        <Style x:Key="LaunchButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{DynamicResource SystemAccentColor}"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemAccentTextColor}"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="LaunchBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect x:Name="LaunchShadow"
                                                  Color="Black"
                                                  Opacity="0.2"
                                                  BlurRadius="0"
                                                  ShadowDepth="0"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- 鼠标进入：缩放 1.05 + 阴影增强 -->
                            <EventTrigger RoutedEvent="Mouse.MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                         To="1.05" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                         To="1.05" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="LaunchShadow"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.4" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="LaunchShadow"
                                                         Storyboard.TargetProperty="BlurRadius"
                                                         To="20" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <!-- 鼠标离开：还原 -->
                            <EventTrigger RoutedEvent="Mouse.MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                         To="1" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                         To="1" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="LaunchShadow"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.2" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="LaunchShadow"
                                                         Storyboard.TargetProperty="BlurRadius"
                                                         To="0" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 进度条样式：ProgressPercent = -1 时不定进度 -->
        <Style x:Key="ProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="IsIndeterminate" Value="False"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding ProgressPercent}" Value="-1">
                    <Setter Property="IsIndeterminate" Value="True"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 提示信息样式 -->
        <Style x:Key="HintBorderStyle" TargetType="Border">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding HintMessage}" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding HintMessage}" Value="">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 圆形图标按钮样式 -->
        <Style x:Key="IconButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="IconBtnBorder"
                                Background="{DynamicResource SystemControlBackgroundAltMediumBrush}"
                                CornerRadius="22">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="IconBtnBorder" Property="Background" Value="{DynamicResource SystemControlBackgroundAltHighBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- 全屏 Grid：背景透明，让亚克力/壁纸效果透出 -->
    <Grid>
        <!-- ============ 中间区域：版本名 + 状态 ============ -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <!-- 当前版本名（大字）+ 加载时淡入动画（Opacity 0→0.9，0.3s） -->
            <TextBlock Text="{Binding SelectedVersion, FallbackValue='未选择版本'}"
                       FontSize="56" FontWeight="Bold"
                       HorizontalAlignment="Center" Opacity="0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedVersion}" Value="{x:Null}">
                                <Setter Property="Text" Value="未选择版本"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
                <!-- Loaded 时淡入 0.3s -->
                <TextBlock.Triggers>
                    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="0" To="0.9" Duration="0:0:0.3"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </TextBlock.Triggers>
            </TextBlock>

            <!-- 状态文字 -->
            <TextBlock Text="{Binding StatusText}"
                       FontSize="14" Opacity="0.6"
                       HorizontalAlignment="Center" Margin="0,12,0,0"
                       TextWrapping="Wrap" MaxWidth="500"/>

            <!-- 提示信息（目录不存在等） -->
            <Border Style="{StaticResource HintBorderStyle}"
                    Background="{DynamicResource SystemControlBackgroundAltMediumBrush}"
                    CornerRadius="6" Padding="16,10" Margin="0,16,0,0"
                    HorizontalAlignment="Center" MaxWidth="500">
                <TextBlock Text="{Binding HintMessage}" TextWrapping="Wrap" Opacity="0.8"
                           FontSize="13"/>
            </Border>
        </StackPanel>

        <!-- ============ 左下角：账户 + 启动按钮 + 版本下拉 ============ -->
        <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Left"
                    Margin="32,0,0,32">
            <!-- 账户切换按钮（在启动按钮上方，hover 时轻微上移） -->
            <Button Command="{Binding SwitchAccountCommand}"
                    Margin="0,0,0,12" Padding="12,8"
                    HorizontalAlignment="Left"
                    RenderTransformOrigin="0.5,0.5">
                <Button.RenderTransform>
                    <TranslateTransform Y="0"/>
                </Button.RenderTransform>
                <Button.Triggers>
                    <EventTrigger RoutedEvent="Mouse.MouseEnter">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                 To="-2" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="Mouse.MouseLeave">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                 To="0" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Button.Triggers>
                <StackPanel Orientation="Horizontal">
                    <!-- 账户头像 -->
                    <Border Width="28" Height="28" CornerRadius="14" ClipToBounds="True"
                            Margin="0,0,10,0">
                        <Border.Background>
                            <SolidColorBrush Color="#FFCCCCCC"/>
                        </Border.Background>
                        <Image Source="{Binding CurrentAccountAvatar}" Stretch="Fill"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentAccountName}" FontWeight="SemiBold" FontSize="13"
                                   TextTrimming="CharacterEllipsis" MaxWidth="160"/>
                        <TextBlock Text="{Binding CurrentAccountType}" Opacity="0.5" FontSize="11"/>
                    </StackPanel>
                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.ChevronDown}" FontSize="12"
                                 Margin="8,0,0,0" Opacity="0.5" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- 启动按钮 + 版本下拉 -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 启动按钮（主题色） -->
                <Button Grid.Column="0"
                        x:Name="LaunchButton"
                        Content="{Binding LaunchButtonText}"
                        Command="{Binding LaunchCommand}"
                        IsEnabled="{Binding IsLaunchEnabled}"
                        Style="{StaticResource LaunchButtonStyle}"
                        Height="56" MinWidth="220"
                        Margin="0,0,0,0"/>

                <!-- 版本下拉小箭头（紧挨启动按钮右侧） -->
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding Versions}"
                          SelectedItem="{Binding SelectedVersion, Mode=TwoWay}"
                          MinWidth="200" MaxWidth="300" Height="56"
                          Margin="8,0,0,0"
                          VerticalContentAlignment="Center"
                          ToolTip="选择游戏版本"/>
            </Grid>

            <!-- 进度条（启动时显示） -->
            <ProgressBar Height="3" Margin="0,8,0,0"
                         Style="{StaticResource ProgressBarStyle}"
                         Minimum="0" Maximum="100"
                         Value="{Binding ProgressPercent, Mode=OneWay}"/>
        </StackPanel>

        <!-- ============ 右下角：实例设置按钮 ============ -->
        <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Right"
                    Margin="0,0,32,32">
            <!-- 实例面板/实例设置按钮 -->
            <Button Style="{StaticResource IconButtonStyle}"
                    Command="{Binding OpenInstanceSettingsCommand}"
                    ToolTip="实例面板 / 实例设置">
                <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Settings}" FontSize="18"/>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
