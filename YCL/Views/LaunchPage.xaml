<UserControl x:Class="YCL.Views.LaunchPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
      mc:Ignorable="d"
      d:DesignHeight="640" d:DesignWidth="900"
      Loaded="LaunchPage_Loaded">
    <UserControl.Resources>
        <!-- 错误日志样式（红色） -->
        <Style x:Key="LogListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="4,1"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Foreground" Value="#FFD4D4D4"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsError}" Value="True">
                    <Setter Property="Foreground" Value="#FFD6454A"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 提示信息 Border 样式：HintMessage 为 null 时折叠 -->
        <Style x:Key="HintBorderStyle" TargetType="Border">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding HintMessage}" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding HintMessage}" Value="">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 刷新中按钮禁用样式 -->
        <Style x:Key="RefreshButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsRefreshing}" Value="True">
                    <Setter Property="IsEnabled" Value="False"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="VersionComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsRefreshing}" Value="True">
                    <Setter Property="IsEnabled" Value="False"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 进度条样式：ProgressPercent = -1 时不定进度 -->
        <Style x:Key="ProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="IsIndeterminate" Value="False"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding ProgressPercent}" Value="-1">
                    <Setter Property="IsIndeterminate" Value="True"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- 上方：配置区 -->
            <RowDefinition Height="Auto"/>
            <!-- 中间：启动按钮 + 状态 -->
            <RowDefinition Height="Auto"/>
            <!-- 下方：日志面板 -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ============ 上方：配置区 ============ -->
        <StackPanel Grid.Row="0" Margin="24,16,24,8">
            <!-- 页面标题 -->
            <TextBlock Text="启动游戏" FontSize="32" FontWeight="SemiBold" Margin="0,0,0,16"/>

            <!-- 游戏目录显示 -->
            <TextBlock Text="{Binding MinecraftPathDisplay}" Opacity="0.6" FontSize="13"
                       Margin="0,0,0,12" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>

            <!-- 提示信息（目录不存在 / 没有版本时显示） -->
            <Border Style="{StaticResource HintBorderStyle}"
                    Background="{DynamicResource SystemControlBackgroundAltMediumBrush}"
                    CornerRadius="6" Padding="12,8" Margin="0,0,0,12">
                <TextBlock Text="{Binding HintMessage}" TextWrapping="Wrap" Opacity="0.8"/>
            </Border>

            <!-- 版本选择行 -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="版本：" VerticalAlignment="Center"
                           FontWeight="SemiBold" Margin="0,0,8,0"/>

                <ComboBox Grid.Column="1" x:Name="VersionComboBox"
                          Style="{StaticResource VersionComboBoxStyle}"
                          ItemsSource="{Binding Versions}"
                          SelectedItem="{Binding SelectedVersion, Mode=TwoWay}"
                          MinHeight="32" MinWidth="200" MaxWidth="500"/>

                <Button Grid.Column="2" Content="刷新" Margin="8,0,0,0" MinWidth="72"
                        Style="{StaticResource RefreshButtonStyle}"
                        Command="{Binding RefreshVersionsCommand}"/>
            </Grid>

            <!-- 当前账户显示行 -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="56"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="当前账户：" VerticalAlignment="Center"
                           FontWeight="SemiBold" Margin="0,0,8,0"/>

                <!-- 账户头像：无头像时显示占位色块 -->
                <Border Grid.Column="1" Width="56" Height="56" CornerRadius="4" ClipToBounds="True"
                        VerticalAlignment="Center">
                    <Border.Background>
                        <SolidColorBrush Color="#FFCCCCCC"/>
                    </Border.Background>
                    <Image Source="{Binding CurrentAccountAvatar}" Stretch="Fill"/>
                </Border>

                <StackPanel Grid.Column="3" VerticalAlignment="Center">
                    <TextBlock Text="{Binding CurrentAccountName}" FontWeight="SemiBold" FontSize="14"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding CurrentAccountType}" Opacity="0.6" FontSize="12"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <TextBlock Grid.Column="4" Text="账户管理请到左侧导航" Opacity="0.5" FontSize="11"
                           VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="120"/>
            </Grid>

            <!-- 内存设置 -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="最大内存(MB)：" VerticalAlignment="Center"
                           FontWeight="SemiBold" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1" Text="{Binding MaxMemoryMb, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         MinHeight="32" VerticalContentAlignment="Center" Padding="8,4"/>

                <TextBlock Grid.Column="3" Text="初始内存(MB)：" VerticalAlignment="Center"
                           FontWeight="SemiBold" Margin="0,0,8,0"/>
                <TextBox Grid.Column="4" Text="{Binding MinMemoryMb, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         MinHeight="32" VerticalContentAlignment="Center" Padding="8,4"/>
            </Grid>
        </StackPanel>

        <!-- ============ 中间：启动按钮 + 状态 ============ -->
        <StackPanel Grid.Row="1" Margin="24,4,24,12">
            <!-- 启动按钮：横跨整行，大号显眼 -->
            <Button x:Name="LaunchButton"
                    Content="{Binding LaunchButtonText}"
                    Command="{Binding LaunchCommand}"
                    IsEnabled="{Binding IsLaunchEnabled}"
                    FontSize="18" FontWeight="SemiBold"
                    Height="52" Margin="0,0,0,8"
                    HorizontalAlignment="Stretch"/>

            <!-- 状态文字 + 进度百分比 -->
            <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding StatusText}"
                           VerticalAlignment="Center" Opacity="0.8" TextWrapping="Wrap"/>
                <TextBlock Grid.Column="1" VerticalAlignment="Center" Opacity="0.6"
                           Margin="12,0,0,0">
                    <Run Text="进度："/>
                    <Run Text="{Binding ProgressPercent, Mode=OneWay}"/>
                    <Run Text="%"/>
                </TextBlock>
            </Grid>

            <!-- 进度条 -->
            <ProgressBar Height="4" Margin="0,4,0,0" Style="{StaticResource ProgressBarStyle}"
                         Minimum="0" Maximum="100"
                         Value="{Binding ProgressPercent, Mode=OneWay}"/>
        </StackPanel>

        <!-- ============ 下方：日志面板 ============ -->
        <Grid Grid.Row="2" Margin="24,4,24,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 日志面板标题 + 清空按钮 -->
            <Grid Grid.Row="0" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="游戏日志" FontSize="14" FontWeight="SemiBold"
                           Opacity="0.8" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="清空" Command="{Binding ClearLogsCommand}"
                        Padding="12,2" MinWidth="56"/>
            </Grid>

            <!-- 日志列表：用 ListBox 显示多行日志，自动滚动到底部 -->
            <Border Grid.Row="1" Background="#FF1E1E1E" CornerRadius="4"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                    BorderThickness="1">
                <ListBox x:Name="LogListBox"
                         ItemsSource="{Binding LogEntries}"
                         ItemContainerStyle="{StaticResource LogListBoxItemStyle}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         Margin="2"
                         IsTextSearchEnabled="False">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Text}" TextWrapping="NoWrap"
                                       Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem},
                                                            Path=Foreground}"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </Grid>
    </Grid>
</UserControl>
