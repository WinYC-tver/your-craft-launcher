<UserControl x:Class="YCL.Views.JavaPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="800"
      Loaded="JavaPage_Loaded">
    <UserControl.Resources>
        <!-- 提示信息 Border 样式：StatusMessage 为 null 或空时折叠 -->
        <Style x:Key="HintBorderStyle" TargetType="Border">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding StatusMessage}" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusMessage}" Value="">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 安装进度区样式：IsInstalling 为 false 时折叠 -->
        <Style x:Key="InstallProgressStyle" TargetType="StackPanel">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsInstalling}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 安装进度条样式：InstallPercent = -1 时不定进度 -->
        <Style x:Key="InstallProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="IsIndeterminate" Value="False"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding InstallPercent}" Value="-1">
                    <Setter Property="IsIndeterminate" Value="True"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Java 卡片样式：IsCurrent 为 true 时高亮边框 -->
        <Style x:Key="JavaCardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseLowBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundAccentBrush}"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 卡片按钮统一样式 -->
        <Style x:Key="CardButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding" Value="10,3"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="MinWidth" Value="72"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- 顶部：标题 -->
            <RowDefinition Height="Auto"/>
            <!-- 操作栏：刷新 / 安装 Java / 手动添加 -->
            <RowDefinition Height="Auto"/>
            <!-- 安装进度区 -->
            <RowDefinition Height="Auto"/>
            <!-- 提示信息 -->
            <RowDefinition Height="Auto"/>
            <!-- Java 列表 -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ============ 顶部：标题（咖啡图标，更符合 Java Logo） ============ -->
        <StackPanel Grid.Row="0" Margin="24,16,24,4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="☕" FontSize="32" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <TextBlock Text="Java 管理" FontSize="32" FontWeight="SemiBold"/>
            </StackPanel>
            <TextBlock Text="管理启动游戏使用的 Java 运行时（支持自动检测、在线安装、手动添加）"
                       Opacity="0.6" FontSize="13" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- ============ 操作栏 ============ -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="24,8,24,8">
            <Button Content="检测 Java" Command="{Binding RefreshCommand}"
                    Padding="16,4" MinWidth="96" Margin="0,0,8,0">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsDetecting}" Value="True">
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="在线安装 Java" Command="{Binding InstallJavaOnlineCommand}"
                    Padding="16,4" MinWidth="120" Margin="0,0,8,0"
                    ToolTip="打开 BellSoft（Liberica JDK）下载页面"/>
            <Button Content="自动选择" Command="{Binding AutoSelectJavaCommand}"
                    Padding="16,4" MinWidth="96" Margin="0,0,8,0"
                    ToolTip="根据当前游戏版本自动选择最合适的 Java；未指定版本时选择最新版本"/>
            <Button Content="安装 Java" Command="{Binding InstallJavaCommand}"
                    Padding="16,4" MinWidth="96" Margin="0,0,8,0">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsInstalling}" Value="True">
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsDetecting}" Value="True">
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="手动添加" Command="{Binding AddManuallyCommand}"
                    Padding="16,4" MinWidth="96" Margin="0,0,16,0"/>
        </StackPanel>

        <!-- ============ 安装进度区 ============ -->
        <StackPanel Grid.Row="2" Margin="24,4,24,8" Style="{StaticResource InstallProgressStyle}">
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" Opacity="0.8"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Column="1" VerticalAlignment="Center" Opacity="0.7" Margin="12,0,0,0">
                    <Run Text="进度："/>
                    <Run Text="{Binding InstallPercent, Mode=OneWay, StringFormat=F1}"/>
                    <Run Text="%"/>
                </TextBlock>
            </Grid>
            <ProgressBar Height="6" Margin="0,2,0,8"
                         Style="{StaticResource InstallProgressBarStyle}"
                         Minimum="0" Maximum="100"
                         Value="{Binding InstallPercent, Mode=OneWay}"/>
            <Button Content="取消安装" Command="{Binding CancelInstallCommand}"
                    Padding="12,3" MinWidth="80" HorizontalAlignment="Left"/>
        </StackPanel>

        <!-- ============ 提示信息 ============ -->
        <Border Grid.Row="3" Style="{StaticResource HintBorderStyle}"
                Background="{DynamicResource SystemControlBackgroundAltMediumBrush}"
                CornerRadius="6" Padding="12,8" Margin="24,4,24,8">
            <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Opacity="0.8"/>
        </Border>

        <!-- ============ Java 列表 ============ -->
        <Grid Grid.Row="4" Margin="24,4,24,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 列表标题 + 数量 -->
            <Grid Grid.Row="0" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="已检测到的 Java 运行时" FontSize="14" FontWeight="SemiBold"
                           Opacity="0.8" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" VerticalAlignment="Center" Opacity="0.6">
                    <Run Text="共 "/>
                    <Run Text="{Binding Javas.Count, Mode=OneWay}"/>
                    <Run Text=" 个"/>
                </TextBlock>
            </Grid>

            <!-- Java 卡片列表 -->
            <Border Grid.Row="1"
                    Background="{DynamicResource SystemControlBackgroundAltMediumBrush}"
                    CornerRadius="4"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                    BorderThickness="1">
                <ListBox ItemsSource="{Binding Javas}"
                         SelectedItem="{Binding SelectedJava, Mode=TwoWay}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         Margin="2"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="2"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="2,3" Padding="12,10"
                                    Style="{StaticResource JavaCardBorderStyle}"
                                    CornerRadius="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 左侧：版本信息 + 路径 -->
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"
                                                       FontSize="15" VerticalAlignment="Center"/>
                                            <!-- "默认" 标记：仅当前 Java 显示 -->
                                            <Border Background="#FF0078D7" CornerRadius="3"
                                                    Padding="6,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="默认" FontSize="11" Foreground="White"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Path, Mode=OneWay}"
                                                   Opacity="0.5" FontSize="11"
                                                   Margin="0,4,0,0" TextTrimming="CharacterEllipsis"
                                                   MaxWidth="500"/>
                                    </StackPanel>

                                    <!-- 右侧：操作按钮 -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <Button Content="设为默认"
                                                Style="{StaticResource CardButtonStyle}"
                                                Command="{Binding DataContext.SetAsCurrentCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </Grid>
    </Grid>
</UserControl>
