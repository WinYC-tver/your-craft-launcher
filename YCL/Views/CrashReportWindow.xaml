<Window x:Class="YCL.Views.CrashReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
        Title="游戏崩溃了 - YCL 启动器"
        Width="900" Height="640"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        MinWidth="640" MinHeight="480"
        Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ============ 顶部：标题 + 大图标 ============ -->
        <Border Grid.Row="0" Background="#FFB71C1C" Padding="32,24">
            <StackPanel Orientation="Horizontal">
                <!-- 警告图标 -->
                <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Warning}" FontSize="42"
                             Foreground="White" VerticalAlignment="Center" Margin="0,0,20,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="游戏崩溃了" Foreground="White" FontSize="28" FontWeight="Bold"/>
                    <TextBlock x:Name="SubtitleText" Foreground="#88FFFFFF" FontSize="13"
                               Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ============ 中间：崩溃信息 + 解决方案 + 报告路径 ============ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="32,20">
            <StackPanel>
                <!-- 解决方案列表（如果有） -->
                <TextBlock Text="可能的解决方案" FontSize="18" FontWeight="SemiBold"
                           Margin="0,0,0,12" Opacity="0.85"/>
                <ItemsControl x:Name="SolutionsList" Margin="0,0,0,20">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource SystemControlBackgroundAltMediumBrush}"
                                    CornerRadius="6" Padding="16,12" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Lightbulb}" FontSize="18"
                                                 Margin="0,0,12,0" VerticalAlignment="Top" Opacity="0.7"/>
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" FontSize="13"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- 没有匹配建议时的兜底提示 -->
                <Border x:Name="NoSolutionHint" Background="{DynamicResource SystemControlBackgroundAltMediumBrush}"
                        CornerRadius="6" Padding="16,12" Margin="0,0,0,20" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Info}" FontSize="18"
                                     Margin="0,0,12,0" VerticalAlignment="Top" Opacity="0.7"/>
                        <TextBlock Text="未匹配到已知崩溃模式。请查看下方完整游戏日志，或在设置页打开崩溃报告文件夹查找详细报告。"
                                   TextWrapping="Wrap" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- 崩溃报告路径 -->
                <TextBlock Text="崩溃报告" FontSize="18" FontWeight="SemiBold"
                           Margin="0,0,0,12" Opacity="0.85"/>
                <Border Background="{DynamicResource SystemControlBackgroundAltMediumBrush}"
                        CornerRadius="6" Padding="16,12">
                    <StackPanel>
                        <TextBlock x:Name="ReportPathText" TextWrapping="Wrap" FontSize="13"
                                   Opacity="0.7" TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="ReportFailText" Text="崩溃报告生成失败，请查看启动器日志了解详情。"
                                   TextWrapping="Wrap" FontSize="13" Opacity="0.7"
                                   Foreground="#FFEF5350" Visibility="Collapsed"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- ============ 底部：操作按钮 ============ -->
        <Border Grid.Row="2" Background="{DynamicResource SystemControlBackgroundAltMediumBrush}"
                Padding="32,16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CopyPathButton" Content="复制报告路径" Padding="16,8"
                        MinWidth="120" Margin="0,0,8,0" Click="CopyPathButton_Click"/>
                <Button x:Name="OpenFolderButton" Content="打开报告文件夹" Padding="16,8"
                        MinWidth="140" Margin="0,0,8,0" Click="OpenFolderButton_Click"
                        Style="{StaticResource AccentButtonStyle}"/>
                <Button x:Name="CloseButton" Content="关闭" Padding="16,8"
                        MinWidth="100" Click="CloseButton_Click" IsCancel="True"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
