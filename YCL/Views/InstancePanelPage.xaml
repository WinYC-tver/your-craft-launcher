<UserControl x:Class="YCL.Views.InstancePanelPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
      mc:Ignorable="d"
      d:DesignHeight="700" d:DesignWidth="1000">
    <UserControl.Resources>
        <!-- 布尔转可见性转换器（用于 IsModded → 徽章显示） -->
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- 详情区样式：选中实例为 null 时折叠 -->
        <Style x:Key="DetailContainerStyle" TargetType="ScrollViewer">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedInstance}" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 空状态样式：选中实例为 null 时显示 -->
        <Style x:Key="EmptyStateStyle" TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedInstance}" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 加载中遮罩样式 -->
        <Style x:Key="LoadingStyle" TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsLoading}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 小组件卡片样式 -->
        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAltMediumBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- 顶部：标题 + 刷新按钮 -->
            <RowDefinition Height="Auto"/>
            <!-- 顶部小组件区 -->
            <RowDefinition Height="Auto"/>
            <!-- 主体两栏：左列表 + 右详情 -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ============ 顶部：标题 + 刷新按钮 ============ -->
        <Grid Grid.Row="0" Margin="24,16,24,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <TextBlock Text="实例面板" FontSize="32" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding Instances.Count, StringFormat='共 {0} 个实例'}"
                           Opacity="0.5" FontSize="13" VerticalAlignment="Bottom"
                           Margin="12,0,0,4"/>
            </StackPanel>
            <Button Grid.Column="1" Command="{Binding LoadInstancesCommand}"
                    Padding="12,6" MinWidth="92" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Sync}" Margin="0,0,8,0"/>
                    <TextBlock Text="刷新"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- ============ 顶部小组件统计区 ============ -->
        <UniformGrid Grid.Row="1" Rows="1" Columns="5" Margin="24,4,24,12">
            <!-- 上次游玩 -->
            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Opacity="0.6">
                        <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.History}" FontSize="14" Margin="0,0,6,0"/>
                        <TextBlock Text="上次游玩" FontSize="12"/>
                    </StackPanel>
                    <TextBlock Text="{Binding LastPlayedText}" FontSize="15" FontWeight="SemiBold"
                               Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Border>
            <!-- 模组数 -->
            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Opacity="0.6">
                        <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Puzzle}" FontSize="14" Margin="0,0,6,0"/>
                        <TextBlock Text="模组" FontSize="12"/>
                    </StackPanel>
                    <TextBlock Text="{Binding ModCount}" FontSize="22" FontWeight="SemiBold" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <!-- 存档数 -->
            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Opacity="0.6">
                        <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Save}" FontSize="14" Margin="0,0,6,0"/>
                        <TextBlock Text="存档" FontSize="12"/>
                    </StackPanel>
                    <TextBlock Text="{Binding SaveCount}" FontSize="22" FontWeight="SemiBold" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <!-- 截图数 -->
            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Opacity="0.6">
                        <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Camera}" FontSize="14" Margin="0,0,6,0"/>
                        <TextBlock Text="截图" FontSize="12"/>
                    </StackPanel>
                    <TextBlock Text="{Binding ScreenshotCount}" FontSize="22" FontWeight="SemiBold" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <!-- 资源包数 -->
            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Opacity="0.6">
                        <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Package}" FontSize="14" Margin="0,0,6,0"/>
                        <TextBlock Text="资源包" FontSize="12"/>
                    </StackPanel>
                    <TextBlock Text="{Binding ResourcePackCount}" FontSize="22" FontWeight="SemiBold" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- ============ 主体两栏：左实例列表 + 右详情 ============ -->
        <Grid Grid.Row="2" Margin="24,0,24,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左栏：实例列表 -->
            <Border Grid.Column="0" Background="{DynamicResource SystemControlBackgroundAltMediumBrush}"
                    CornerRadius="8" Margin="0,0,8,0" Padding="4">
                <Grid>
                    <ListBox ItemsSource="{Binding Instances}"
                             SelectedItem="{Binding SelectedInstance, Mode=TwoWay}"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                <Setter Property="Padding" Value="8,6"/>
                                <Setter Property="Margin" Value="0,2"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <!-- 版本 Id -->
                                    <TextBlock Text="{Binding Id}" FontWeight="SemiBold" FontSize="14"
                                               TextTrimming="CharacterEllipsis"/>
                                    <!-- 类型徽章 + 模组加载器 -->
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                                                CornerRadius="3" Padding="6,1" Margin="0,0,4,0">
                                            <TextBlock Text="{Binding Type}" FontSize="11" Opacity="0.8"/>
                                        </Border>
                                        <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                                                CornerRadius="3" Padding="6,1"
                                                Visibility="{Binding IsModded, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="{Binding ModLoaderName}" FontSize="11" Opacity="0.8"/>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- 加载中提示 -->
                    <Border Style="{StaticResource LoadingStyle}"
                            Background="#80000000" CornerRadius="8">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <ui:ProgressRing IsActive="True" Width="32" Height="32"/>
                            <TextBlock Text="加载中..." Foreground="White" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- 右栏：详情区 -->
            <Border Grid.Column="1" Background="{DynamicResource SystemControlBackgroundAltMediumBrush}"
                    CornerRadius="8" ClipToBounds="True">
                <Grid>
                    <!-- 详情内容（选中实例时显示） -->
                    <ScrollViewer Style="{StaticResource DetailContainerStyle}"
                                  VerticalScrollBarVisibility="Auto" Padding="20,16">
                        <StackPanel>
                            <!-- ============ 基本信息 ============ -->
                            <TextBlock Text="基本信息" FontSize="18" FontWeight="SemiBold"
                                       Margin="0,0,0,8" Opacity="0.8"/>
                            <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                                    CornerRadius="6" Padding="12,10" Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="版本 Id：" Opacity="0.6" Margin="0,0,8,4"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedInstance.Id}" FontWeight="SemiBold" Margin="0,0,0,4"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="类型：" Opacity="0.6" Margin="0,0,8,4"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedInstance.Type}" Margin="0,0,0,4"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="模组加载器：" Opacity="0.6" Margin="0,0,8,4"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,0,0,4">
                                        <Run Text="{Binding SelectedInstance.ModLoaderName, Mode=OneWay, TargetNullValue=无}"/>
                                    </TextBlock>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="父版本：" Opacity="0.6" Margin="0,0,8,4"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,0,0,4">
                                        <Run Text="{Binding SelectedInstance.ParentVersionId, Mode=OneWay, TargetNullValue=无}"/>
                                    </TextBlock>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="目录路径：" Opacity="0.6" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedInstance.Directory}"
                                               TextTrimming="CharacterEllipsis" Opacity="0.8"/>
                                </Grid>
                            </Border>

                            <!-- ============ 模组列表 ============ -->
                            <TextBlock FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" Opacity="0.8">
                                <Run Text="模组"/>
                                <Run Text=" ("/>
                                <Run Text="{Binding Mods.Count, Mode=OneWay}"/>
                                <Run Text=")"/>
                            </TextBlock>
                            <ItemsControl ItemsSource="{Binding Mods}" Margin="0,0,0,16">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                                                CornerRadius="4" Padding="10,6" Margin="0,2">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding FileName}" FontSize="11" Opacity="0.6"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="{Binding Version}" Opacity="0.7"
                                                           VerticalAlignment="Center" Margin="8,0"/>
                                                <Border Grid.Column="2" CornerRadius="3" Padding="6,2"
                                                        VerticalAlignment="Center" Margin="8,0,0,0">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseMediumBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Enabled}" Value="True">
                                                                    <Setter Property="Background" Value="#388E3C"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock FontSize="11" Foreground="White">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="已禁用"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Enabled}" Value="True">
                                                                        <Setter Property="Text" Value="已启用"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- ============ 世界（存档）列表 ============ -->
                            <TextBlock FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" Opacity="0.8">
                                <Run Text="世界"/>
                                <Run Text=" ("/>
                                <Run Text="{Binding Saves.Count, Mode=OneWay}"/>
                                <Run Text=")"/>
                            </TextBlock>
                            <ItemsControl ItemsSource="{Binding Saves}" Margin="0,0,0,16">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                                                CornerRadius="4" Padding="10,6" Margin="0,2">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Name}" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Grid.Column="1" Text="{Binding LastModifiedDisplay}" Opacity="0.7"
                                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- ============ 资源包列表 ============ -->
                            <TextBlock FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" Opacity="0.8">
                                <Run Text="资源包"/>
                                <Run Text=" ("/>
                                <Run Text="{Binding ResourcePacks.Count, Mode=OneWay}"/>
                                <Run Text=")"/>
                            </TextBlock>
                            <ItemsControl ItemsSource="{Binding ResourcePacks}" Margin="0,0,0,16">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                                                CornerRadius="4" Padding="10,6" Margin="0,2">
                                            <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- ============ 光影包列表 ============ -->
                            <TextBlock FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" Opacity="0.8">
                                <Run Text="光影包"/>
                                <Run Text=" ("/>
                                <Run Text="{Binding Shaders.Count, Mode=OneWay}"/>
                                <Run Text=")"/>
                            </TextBlock>
                            <ItemsControl ItemsSource="{Binding Shaders}" Margin="0,0,0,16">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                                                CornerRadius="4" Padding="10,6" Margin="0,2">
                                            <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- ============ 截图列表（缩略图） ============ -->
                            <TextBlock FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" Opacity="0.8">
                                <Run Text="截图"/>
                                <Run Text=" ("/>
                                <Run Text="{Binding Screenshots.Count, Mode=OneWay}"/>
                                <Run Text=")"/>
                            </TextBlock>
                            <ItemsControl ItemsSource="{Binding Screenshots}" Margin="0,0,0,8">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                                                CornerRadius="4" Padding="4" Margin="4">
                                            <StackPanel Width="128">
                                                <Image Source="{Binding FilePath}" Stretch="UniformToFill"
                                                       Height="90" Width="120"/>
                                                <TextBlock Text="{Binding FileName}" FontSize="10" Opacity="0.6"
                                                           TextTrimming="CharacterEllipsis" Margin="0,4,0,0"
                                                           HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- 空状态：未选中实例 -->
                    <Border Style="{StaticResource EmptyStateStyle}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.ViewAll}" FontSize="48" Opacity="0.6"
                                         HorizontalAlignment="Center" Margin="0,0,0,12"/>
                            <TextBlock Text="请选择一个实例" FontSize="16" Opacity="0.7"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
