<UserControl x:Class="YCL.Views.FunctionsHubPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="900">
    <UserControl.Resources>
        <!-- 卡片样式：圆角 + 悬浮抬升效果 -->
        <Style x:Key="FunctionCardStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ControlTemplate.Resources>
                            <!-- Storyboard 定义在 ControlTemplate.Resources 中，让 Triggers 能用 StaticResource 找到 -->
                            <Storyboard x:Key="HoverStoryboard">
                                <DoubleAnimation Storyboard.TargetName="CardBorder"
                                                  Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                  To="-4" Duration="0:0:0.15"/>
                            </Storyboard>
                            <Storyboard x:Key="LeaveStoryboard">
                                <DoubleAnimation Storyboard.TargetName="CardBorder"
                                                  Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                  To="0" Duration="0:0:0.15"/>
                            </Storyboard>
                        </ControlTemplate.Resources>
                        <Border x:Name="CardBorder"
                                Background="{DynamicResource SystemControlBackgroundAltMediumBrush}"
                                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="20,18"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TranslateTransform Y="0"/>
                            </Border.RenderTransform>
                            <ContentPresenter Content="{TemplateBinding Content}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard Storyboard="{StaticResource HoverStoryboard}"/>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard Storyboard="{StaticResource LeaveStoryboard}"/>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,16,24,24">
            <!-- 页面标题 -->
            <TextBlock Text="功能" FontSize="32" FontWeight="SemiBold" Margin="0,0,0,16"/>

            <!-- 卡片网格 -->
            <UniformGrid Columns="3" Rows="2" Margin="0,0,0,0">

                <!-- 联机 -->
                <Button Style="{StaticResource FunctionCardStyle}" Margin="0,0,12,12"
                        Command="{Binding NavigateCommand}" CommandParameter="Multiplayer">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Connect}" FontSize="32" Margin="0,0,16,0" VerticalAlignment="Center"/>
                        <StackPanel>
                            <TextBlock Text="联机" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock Text="Terracotta 联机平台" Opacity="0.6" FontSize="12" Margin="0,4,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Button>

                <!-- 实例面板 -->
                <Button Style="{StaticResource FunctionCardStyle}" Margin="0,0,12,12"
                        Command="{Binding NavigateCommand}" CommandParameter="Instance">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.ViewAll}" FontSize="32" Margin="0,0,16,0" VerticalAlignment="Center"/>
                        <StackPanel>
                            <TextBlock Text="实例面板" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock Text="查看与管理游戏实例" Opacity="0.6" FontSize="12" Margin="0,4,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Button>

                <!-- Java -->
                <Button Style="{StaticResource FunctionCardStyle}" Margin="0,0,0,12"
                        Command="{Binding NavigateCommand}" CommandParameter="Java">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.DeveloperTools}" FontSize="32" Margin="0,0,16,0" VerticalAlignment="Center"/>
                        <StackPanel>
                            <TextBlock Text="Java" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock Text="Java 运行时管理" Opacity="0.6" FontSize="12" Margin="0,4,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Button>

                <!-- 账户 -->
                <Button Style="{StaticResource FunctionCardStyle}" Margin="0,0,12,0"
                        Command="{Binding NavigateCommand}" CommandParameter="Account">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Contact}" FontSize="32" Margin="0,0,16,0" VerticalAlignment="Center"/>
                        <StackPanel>
                            <TextBlock Text="账户" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock Text="微软 / 外置账户管理" Opacity="0.6" FontSize="12" Margin="0,4,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Button>

                <!-- 存档 -->
                <Button Style="{StaticResource FunctionCardStyle}" Margin="0,0,12,0"
                        Command="{Binding NavigateCommand}" CommandParameter="Saves">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Save}" FontSize="32" Margin="0,0,16,0" VerticalAlignment="Center"/>
                        <StackPanel>
                            <TextBlock Text="存档" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock Text="浏览与备份存档" Opacity="0.6" FontSize="12" Margin="0,4,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Button>

                <!-- 截图 -->
                <Button Style="{StaticResource FunctionCardStyle}" Margin="0,0,0,0"
                        Command="{Binding NavigateCommand}" CommandParameter="Screenshots">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Camera}" FontSize="32" Margin="0,0,16,0" VerticalAlignment="Center"/>
                        <StackPanel>
                            <TextBlock Text="截图" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock Text="浏览游戏截图" Opacity="0.6" FontSize="12" Margin="0,4,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Button>

            </UniformGrid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
