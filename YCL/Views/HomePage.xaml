<UserControl x:Class="YCL.Views.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
      mc:Ignorable="d"
      d:DesignHeight="640" d:DesignWidth="900"
      Loaded="HomePage_Loaded">
    <UserControl.Resources>
        <!-- 提示信息 Border 样式：HintMessage 为 null 或空时折叠 -->
        <Style x:Key="HintBorderStyle" TargetType="Border">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding HintMessage}" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding HintMessage}" Value="">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 安装进度区样式：IsInstalling 为 false 时折叠 -->
        <Style x:Key="InstallProgressStyle" TargetType="StackPanel">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsInstalling}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 安装进度条样式：InstallPercent = -1 时不定进度 -->
        <Style x:Key="InstallProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="IsIndeterminate" Value="False"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding InstallPercent}" Value="-1">
                    <Setter Property="IsIndeterminate" Value="True"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 版本类型友好显示样式：根据 Type 值切换中文文字 -->
        <Style x:Key="VersionTypeTextStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Text" Value="{Binding Type}"/>
            <Setter Property="Opacity" Value="0.6"/>
            <Setter Property="FontSize" Value="12"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Type}" Value="release">
                    <Setter Property="Text" Value="正式版"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Type}" Value="snapshot">
                    <Setter Property="Text" Value="快照版"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Type}" Value="old_beta">
                    <Setter Property="Text" Value="旧 Beta 版"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Type}" Value="old_alpha">
                    <Setter Property="Text" Value="旧 Alpha 版"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 模组加载器标记样式：IsModded 为 false 时折叠 -->
        <Style x:Key="ModLoaderBadgeStyle" TargetType="Border">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsModded}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 继承父版本标记样式：HasInheritsFrom 为 false 时折叠 -->
        <Style x:Key="InheritsBadgeStyle" TargetType="Border">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasInheritsFrom}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 卡片操作按钮统一样式：紧凑、小号 -->
        <Style x:Key="CardButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding" Value="10,3"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="MinWidth" Value="56"/>
        </Style>

        <!-- "安装加载器"按钮：仅原版（非模组、非继承）版本显示 -->
        <Style x:Key="InstallLoaderButtonStyle" TargetType="Button" BasedOn="{StaticResource CardButtonStyle}">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsModded}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding HasInheritsFrom}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- "卸载加载器"按钮：仅已装加载器或继承版本显示 -->
        <Style x:Key="UninstallLoaderButtonStyle" TargetType="Button" BasedOn="{StaticResource CardButtonStyle}">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsModded}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding HasInheritsFrom}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- 顶部：标题 + 游戏目录 -->
            <RowDefinition Height="Auto"/>
            <!-- 操作栏：刷新 / 安装新版本 / 版本隔离 / 安装状态 -->
            <RowDefinition Height="Auto"/>
            <!-- 安装进度区（仅安装时显示） -->
            <RowDefinition Height="Auto"/>
            <!-- 提示信息 -->
            <RowDefinition Height="Auto"/>
            <!-- 已安装版本列表 -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ============ 顶部：标题 + 游戏目录 ============ -->
        <StackPanel Grid.Row="0" Margin="24,16,24,4">
            <TextBlock Text="主页" FontSize="32" FontWeight="SemiBold"/>
            <TextBlock Text="{Binding MinecraftPathDisplay}" Opacity="0.6" FontSize="13"
                       Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
        </StackPanel>

        <!-- ============ 操作栏 ============ -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="24,8,24,8">
            <Button Content="刷新" Command="{Binding RefreshCommand}"
                    Padding="16,4" MinWidth="80" Margin="0,0,8,0">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRefreshing}" Value="True">
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="安装新版本" Command="{Binding InstallNewVersionCommand}"
                    Padding="16,4" MinWidth="100" Margin="0,0,16,0"/>

            <!-- 版本隔离开关 -->
            <CheckBox Content="版本隔离（每个版本独立 mods/saves）"
                      IsChecked="{Binding EnableVersionIsolation, Mode=TwoWay}"
                      VerticalAlignment="Center" Margin="0,0,16,0"
                      ToolTip="启用后每个版本拥有独立的 mods/saves/configs 等目录，互不影响"/>

            <!-- 安装状态文字 -->
            <TextBlock Text="{Binding InstallStatus}" VerticalAlignment="Center"
                       Opacity="0.7" Margin="8,0,0,0" TextTrimming="CharacterEllipsis"/>
        </StackPanel>

        <!-- ============ 安装进度区（仅安装时显示） ============ -->
        <StackPanel Grid.Row="2" Margin="24,4,24,8" Style="{StaticResource InstallProgressStyle}">
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding InstallStatus}" Opacity="0.8"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Column="1" VerticalAlignment="Center" Opacity="0.7" Margin="12,0,0,0">
                    <Run Text="进度："/>
                    <Run Text="{Binding InstallPercent, Mode=OneWay, StringFormat=F1}"/>
                    <Run Text="%"/>
                </TextBlock>
            </Grid>
            <ProgressBar Height="6" Margin="0,2,0,8"
                         Style="{StaticResource InstallProgressBarStyle}"
                         Minimum="0" Maximum="100"
                         Value="{Binding InstallPercent, Mode=OneWay}"/>
            <!-- 取消安装按钮 -->
            <Button Content="取消安装" Command="{Binding CancelInstallCommand}"
                    Padding="12,3" MinWidth="80" HorizontalAlignment="Left"/>
        </StackPanel>

        <!-- ============ 提示信息 ============ -->
        <Border Grid.Row="3" Style="{StaticResource HintBorderStyle}"
                Background="{DynamicResource SystemControlBackgroundAltMediumBrush}"
                CornerRadius="6" Padding="12,8" Margin="24,4,24,8">
            <TextBlock Text="{Binding HintMessage}" TextWrapping="Wrap" Opacity="0.8"/>
        </Border>

        <!-- ============ 已安装版本列表 ============ -->
        <Grid Grid.Row="4" Margin="24,4,24,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 列表标题 + 数量 -->
            <Grid Grid.Row="0" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="已安装版本" FontSize="14" FontWeight="SemiBold"
                           Opacity="0.8" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" VerticalAlignment="Center" Opacity="0.6">
                    <Run Text="共 "/>
                    <Run Text="{Binding InstalledVersions.Count, Mode=OneWay}"/>
                    <Run Text=" 个版本"/>
                </TextBlock>
            </Grid>

            <!-- 版本卡片列表 -->
            <Border Grid.Row="1"
                    Background="{DynamicResource SystemControlBackgroundAltMediumBrush}"
                    CornerRadius="4"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                    BorderThickness="1">
                <ListBox ItemsSource="{Binding InstalledVersions}"
                         SelectedItem="{Binding SelectedVersion, Mode=TwoWay}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         Margin="2"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="2"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="2,3" Padding="12,10"
                                    Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                                    CornerRadius="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 左侧：版本 id + 类型 + 标记 -->
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Id}" FontWeight="SemiBold"
                                                       FontSize="15" VerticalAlignment="Center"/>
                                            <!-- 模组加载器标记 -->
                                            <Border Style="{StaticResource ModLoaderBadgeStyle}"
                                                    Background="#FF6750A4" CornerRadius="3"
                                                    Padding="6,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding ModLoaderName}"
                                                           FontSize="11" Foreground="White"/>
                                            </Border>
                                            <!-- 继承父版本标记 -->
                                            <Border Style="{StaticResource InheritsBadgeStyle}"
                                                    Background="#FF0078D7" CornerRadius="3"
                                                    Padding="6,1" Margin="4,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="继承版本" FontSize="11" Foreground="White"/>
                                            </Border>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Style="{StaticResource VersionTypeTextStyle}"/>
                                            <TextBlock Text=" · " Opacity="0.4" FontSize="12"/>
                                            <TextBlock Text="{Binding Directory, StringFormat='  {0}',
                                                       Mode=OneWay}" Opacity="0.4" FontSize="11"
                                                       TextTrimming="CharacterEllipsis" MaxWidth="400"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- 右侧：操作按钮 -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <Button Content="启动" Style="{StaticResource CardButtonStyle}"
                                                Command="{Binding DataContext.LaunchVersionCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Content="打开" Style="{StaticResource CardButtonStyle}"
                                                Command="{Binding DataContext.OpenVersionFolderCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Content="安装加载器" Style="{StaticResource InstallLoaderButtonStyle}"
                                                Command="{Binding DataContext.InstallModLoaderCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="为此版本安装 Forge/Fabric/Quilt/NeoForge/LiteLoader 模组加载器"/>
                                        <Button Content="卸载加载器" Style="{StaticResource UninstallLoaderButtonStyle}"
                                                Command="{Binding DataContext.UninstallModLoaderCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="卸载此版本已安装的模组加载器"/>
                                        <Button Content="重命名" Style="{StaticResource CardButtonStyle}"
                                                Command="{Binding DataContext.RenameVersionCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Content="复制" Style="{StaticResource CardButtonStyle}"
                                                Command="{Binding DataContext.CopyVersionCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Content="删除" Style="{StaticResource CardButtonStyle}"
                                                Command="{Binding DataContext.DeleteVersionCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </Grid>
    </Grid>
</UserControl>
