<UserControl x:Class="YCL.Views.MultiplayerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
      mc:Ignorable="d"
      d:DesignHeight="700" d:DesignWidth="900">
    <UserControl.Resources>
        <!-- 下载进度区样式：IsDownloading = false 时折叠 -->
        <Style x:Key="DownloadProgressStyle" TargetType="StackPanel">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDownloading}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 下载按钮文字样式：IsTerracottaReady = true 时显示"重新下载" -->
        <Style x:Key="DownloadButtonTextStyle" TargetType="TextBlock">
            <Setter Property="Text" Value="下载 Terracotta"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsTerracottaReady}" Value="True">
                    <Setter Property="Text" Value="重新下载"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 就绪徽章样式：IsTerracottaReady = true 时显示 -->
        <Style x:Key="ReadyBadgeStyle" TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsTerracottaReady}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,16,24,24">

            <!-- ============ 页面标题 ============ -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="联机" FontSize="32" FontWeight="SemiBold"/>
                <TextBlock Text="陶瓦联机 Terracotta" Opacity="0.6" FontSize="14"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <!-- ============ 信息卡片：说明 Terracotta ============ -->
            <Border Background="{DynamicResource SystemControlBackgroundAltMediumBrush}"
                    CornerRadius="8" Padding="24,20" Margin="0,0,0,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Connect}" FontSize="20" Margin="0,0,8,0" Opacity="0.8"/>
                        <TextBlock Text="什么是 Terracotta？" FontSize="18" FontWeight="SemiBold"/>
                    </StackPanel>
                    <TextBlock Opacity="0.7" TextWrapping="Wrap" LineHeight="22">
                        <Run Text="Terracotta（陶瓦联机）是一个开源的 Minecraft 联机客户端 mod，"/>
                        <Run Text="让玩家无需端口映射、无需公网 IP，即可和朋友联机游玩。"/>
                        <Run Text="它通过隧道技术打通玩家之间的连接，使用简单。"/>
                        <Run Text="项目地址：github.com/burningtnt/Terracotta"/>
                    </TextBlock>
                    <Button Command="{Binding OpenTerracottaCommand}"
                            Padding="16,6" MinWidth="160" HorizontalAlignment="Left"
                            Margin="0,16,0,0">
                        <StackPanel Orientation="Horizontal">
                            <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.World}" Margin="0,0,8,0"/>
                            <TextBlock Text="了解项目"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- ============ Terracotta 下载区 ============ -->
            <Border Background="{DynamicResource SystemControlBackgroundAltMediumBrush}"
                    CornerRadius="8" Padding="24,20" Margin="0,0,0,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Download}" FontSize="20" Margin="0,0,8,0" Opacity="0.8"/>
                        <TextBlock Text="Terracotta 客户端" FontSize="18" FontWeight="SemiBold"/>
                        <!-- 就绪徽章 -->
                        <Border Style="{StaticResource ReadyBadgeStyle}"
                                Background="#388E3C" CornerRadius="10" Padding="8,2"
                                VerticalAlignment="Center" Margin="12,0,0,0">
                            <TextBlock Text="已就绪" FontSize="11" Foreground="White"/>
                        </Border>
                    </StackPanel>

                    <!-- 状态文字 -->
                    <TextBlock Text="{Binding DownloadStatus}" Opacity="0.8"
                               TextWrapping="Wrap" Margin="0,4,0,12"/>

                    <!-- 下载进度条（仅下载中显示） -->
                    <StackPanel Style="{StaticResource DownloadProgressStyle}" Margin="0,0,0,12">
                        <ProgressBar Minimum="0" Maximum="100"
                                     Value="{Binding DownloadProgress, Mode=OneWay}"
                                     Height="6"/>
                        <TextBlock Margin="0,4,0,0" Opacity="0.6" FontSize="12">
                            <Run Text="进度："/>
                            <Run Text="{Binding DownloadProgress, Mode=OneWay, StringFormat=F1}"/>
                            <Run Text="%"/>
                        </TextBlock>
                    </StackPanel>

                    <!-- 下载按钮（下载中禁用，已就绪显示"重新下载"） -->
                    <Button Command="{Binding DownloadTerracottaCommand}"
                            Padding="16,6" MinWidth="160" HorizontalAlignment="Left">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDownloading}" Value="True">
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Download}" Margin="0,0,8,0"/>
                            <TextBlock Style="{StaticResource DownloadButtonTextStyle}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- ============ 联机配置区 ============ -->
            <Border Background="{DynamicResource SystemControlBackgroundAltMediumBrush}"
                    CornerRadius="8" Padding="24,20" Margin="0,0,0,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Settings}" FontSize="20" Margin="0,0,8,0" Opacity="0.8"/>
                        <TextBlock Text="联机配置" FontSize="18" FontWeight="SemiBold"/>
                    </StackPanel>
                    <TextBlock Text="选择要联机的 Minecraft 版本，并填写对方提供的服务器地址。"
                               Opacity="0.6" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12"/>

                    <!-- 版本选择 -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="游戏版本：" Width="92" VerticalAlignment="Center" Opacity="0.7"/>
                        <ComboBox ItemsSource="{Binding Versions}"
                                  SelectedItem="{Binding SelectedVersion, Mode=TwoWay}"
                                  DisplayMemberPath="DisplayName"
                                  MinWidth="240"/>
                    </StackPanel>

                    <!-- 服务器地址 -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="服务器地址：" Width="92" VerticalAlignment="Center" Opacity="0.7"/>
                        <TextBox Text="{Binding ServerAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 MinWidth="320" VerticalAlignment="Center"
                                 ToolTip="例如：terracotta://xxxxx 或 host:port"/>
                    </StackPanel>

                    <!-- 启动按钮 -->
                    <Button Command="{Binding LaunchMultiplayerCommand}"
                            Padding="20,8" MinWidth="160" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Play}" Margin="0,0,8,0"/>
                            <TextBlock Text="启动联机"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
