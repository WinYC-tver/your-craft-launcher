<UserControl x:Class="YCL.Views.DownloadPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
      xmlns:views="clr-namespace:YCL.Views"
      mc:Ignorable="d"
      d:DesignHeight="640" d:DesignWidth="1040">
    <UserControl.Resources>
        <!-- 提示信息 Border 样式：HintMessage 为 null 或空时折叠 -->
        <Style x:Key="HintBorderStyle" TargetType="Border">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding HintMessage}" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding HintMessage}" Value="">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 整体进度条样式：OverallPercent = -1 时不定进度 -->
        <Style x:Key="OverallProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="IsIndeterminate" Value="False"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding OverallPercent}" Value="-1">
                    <Setter Property="IsIndeterminate" Value="True"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 单文件进度条样式 -->
        <Style x:Key="FileProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="IsIndeterminate" Value="False"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="100"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Percent}" Value="-1">
                    <Setter Property="IsIndeterminate" Value="True"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 文件项状态文字样式 -->
        <Style x:Key="FileStatusTextStyle" TargetType="TextBlock">
            <Setter Property="Opacity" Value="0.7"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                    <Setter Property="Foreground" Value="#FF4CAF50"/>
                    <Setter Property="Opacity" Value="1"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsFailed}" Value="True">
                    <Setter Property="Foreground" Value="#FFD6454A"/>
                    <Setter Property="Opacity" Value="1"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <!-- 五大 Tab：游戏下载 / 整合包 / 模组 / 资源包 / 光影 -->
    <TabControl Padding="0" Margin="0">

        <!-- ============ Tab 1：游戏下载 ============ -->
        <TabItem Header="游戏下载">
            <Grid Margin="8,8,8,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 顶部：下载源 + 刷新按钮 -->
                <Grid Grid.Row="0" Margin="16,8,16,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="游戏版本下载" FontSize="24" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>

                    <TextBlock Grid.Column="1" Text="下载源：" VerticalAlignment="Center"
                               Opacity="0.6" Margin="0,0,4,0"/>
                    <TextBlock Grid.Column="2" Text="{Binding DownloadSourceDisplay}"
                               VerticalAlignment="Center" FontWeight="SemiBold" Opacity="0.85"
                               Margin="0,0,12,0"/>

                    <Button Grid.Column="3" Content="刷新版本清单"
                            Command="{Binding RefreshManifestCommand}"
                            Padding="12,4" MinWidth="100"/>
                </Grid>

                <!-- 版本输入 + 控制按钮 -->
                <StackPanel Grid.Row="1" Margin="16,4,16,8">
                    <!-- 提示信息 -->
                    <Border Style="{StaticResource HintBorderStyle}"
                            Background="{DynamicResource SystemControlBackgroundAltMediumBrush}"
                            CornerRadius="6" Padding="12,8" Margin="0,0,0,8">
                        <TextBlock Text="{Binding HintMessage}" TextWrapping="Wrap" Opacity="0.8"/>
                    </Border>

                    <!-- 版本 id 输入行 -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="版本 id：" VerticalAlignment="Center"
                                   FontWeight="SemiBold" Margin="0,0,8,0"/>
                        <TextBox Grid.Column="1" Text="{Binding VersionIdInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 MinHeight="32" VerticalContentAlignment="Center" Padding="8,4"
                                 IsEnabled="{Binding CanStartDownload}"/>
                        <Button Grid.Column="2" Content="开始下载"
                                Command="{Binding StartDownloadCommand}"
                                FontSize="14" FontWeight="SemiBold"
                                Padding="20,4" MinWidth="100" Margin="8,0,0,0"/>
                    </Grid>

                    <!-- 控制按钮行 -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Button Content="暂停" Command="{Binding PauseCommand}"
                                Padding="16,4" MinWidth="80" Margin="0,0,8,0"/>
                        <Button Content="继续" Command="{Binding ResumeCommand}"
                                Padding="16,4" MinWidth="80" Margin="0,0,8,0"/>
                        <Button Content="取消" Command="{Binding CancelCommand}"
                                Padding="16,4" MinWidth="80"/>
                    </StackPanel>
                </StackPanel>

                <!-- 整体进度区 -->
                <StackPanel Grid.Row="2" Margin="16,4,16,8">
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="{Binding StatusText}"
                                   VerticalAlignment="Center" Opacity="0.85" TextWrapping="Wrap"/>
                        <TextBlock Grid.Column="1" VerticalAlignment="Center" Opacity="0.7" Margin="12,0,0,0">
                            <Run Text="进度："/>
                            <Run Text="{Binding OverallPercent, Mode=OneWay, StringFormat=F1}"/>
                            <Run Text="%"/>
                        </TextBlock>
                    </Grid>

                    <ProgressBar Height="8" Margin="0,2,0,8"
                                 Style="{StaticResource OverallProgressBarStyle}"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding OverallPercent, Mode=OneWay}"/>

                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Opacity="0.7">
                            <Run Text="文件："/>
                            <Run Text="{Binding CompletedFiles, Mode=OneWay}"/>
                            <Run Text=" / "/>
                            <Run Text="{Binding TotalFiles, Mode=OneWay}"/>
                            <Run Text="（失败 "/>
                            <Run Text="{Binding FailedFiles, Mode=OneWay}"/>
                            <Run Text="）"/>
                        </TextBlock>

                        <TextBlock Grid.Column="1" VerticalAlignment="Center" Opacity="0.7" Margin="16,0,0,0">
                            <Run Text="已下载："/>
                            <Run Text="{Binding DownloadedBytesDisplay, Mode=OneWay}"/>
                            <Run Text=" / "/>
                            <Run Text="{Binding TotalBytesDisplay, Mode=OneWay}"/>
                        </TextBlock>

                        <TextBlock Grid.Column="2" VerticalAlignment="Center" Opacity="0.7" Margin="16,0,0,0">
                            <Run Text="速度："/>
                            <Run Text="{Binding SpeedDisplay, Mode=OneWay}"/>
                        </TextBlock>
                    </Grid>
                </StackPanel>

                <!-- 下载文件列表 -->
                <Grid Grid.Row="3" Margin="16,4,16,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="下载文件列表" FontSize="14" FontWeight="SemiBold"
                               Opacity="0.8" Margin="0,0,0,4"/>

                    <Border Grid.Row="1"
                            Background="{DynamicResource SystemControlBackgroundAltMediumBrush}"
                            CornerRadius="4"
                            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                            BorderThickness="1">
                        <ListBox ItemsSource="{Binding ActiveFiles}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 Margin="2">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="2,3" Padding="8,6"
                                            Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                                            CornerRadius="4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal"
                                                        Margin="0,0,8,4">
                                                <TextBlock Text="{Binding FileName}" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" MaxWidth="400"/>
                                                <TextBlock Text="{Binding Category, StringFormat='  [{0}]'}"
                                                           Opacity="0.5" FontSize="11" VerticalAlignment="Center"
                                                           Margin="6,0,0,0"/>
                                            </StackPanel>

                                            <TextBlock Grid.Row="0" Grid.Column="1"
                                                       Text="{Binding SpeedDisplay}"
                                                       Style="{StaticResource FileStatusTextStyle}"
                                                       VerticalAlignment="Center"/>

                                            <ProgressBar Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                         Height="3"
                                                         Style="{StaticResource FileProgressBarStyle}"
                                                         Value="{Binding Percent, Mode=OneWay}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Grid>
            </Grid>
        </TabItem>

        <!-- ============ Tab 2：整合包 ============ -->
        <TabItem Header="整合包">
            <Grid Margin="24,16,24,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 标题 + 导入按钮 -->
                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="整合包导入" FontSize="24" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="1" Content="导入整合包"
                            Command="{Binding ImportModpackCommand}"
                            Padding="16,8" MinWidth="120">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsImportingModpack}" Value="True">
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>

                <!-- 状态信息 -->
                <Border Grid.Row="1"
                        Background="{DynamicResource SystemControlBackgroundAltMediumBrush}"
                        CornerRadius="8" Padding="24,16">
                    <StackPanel>
                        <TextBlock Text="{Binding ModpackStatus}" TextWrapping="Wrap" FontSize="14"
                                   Opacity="0.85"/>
                        <TextBlock Text="支持格式：CurseForge 整合包 (.zip)、Modrinth 整合包 (.mrpack)"
                                   Opacity="0.5" FontSize="12" Margin="0,16,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
        </TabItem>

        <!-- ============ Tab 3：模组 ============ -->
        <TabItem Header="模组">
            <!-- 嵌入模组管理页面，DataContext 绑定到 DownloadPageViewModel.ModPageVM -->
            <views:ModPage DataContext="{Binding ModPageVM}"/>
        </TabItem>

        <!-- ============ Tab 4：资源包 ============ -->
        <TabItem Header="资源包">
            <!-- 嵌入资源中心页面，DataContext 绑定到 DownloadPageViewModel.ResourcePageVM -->
            <views:ResourcePage DataContext="{Binding ResourcePageVM}"/>
        </TabItem>

        <!-- ============ Tab 5：光影 ============ -->
        <TabItem Header="光影">
            <Grid Margin="24,16,24,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 标题 + 刷新按钮 -->
                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="光影包管理" FontSize="24" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="1" Content="刷新列表"
                            Command="{Binding RefreshShaderPacksCommand}"
                            Padding="16,8" MinWidth="100"/>
                </Grid>

                <!-- 状态信息 -->
                <TextBlock Grid.Row="1" Text="{Binding ShaderPackStatus}"
                           Opacity="0.7" FontSize="13" Margin="0,0,0,12"
                           TextWrapping="Wrap"/>

                <!-- 光影包列表 -->
                <Border Grid.Row="2"
                        Background="{DynamicResource SystemControlBackgroundAltMediumBrush}"
                        CornerRadius="4"
                        BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                        BorderThickness="1">
                    <ListBox ItemsSource="{Binding ShaderPacks}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             Margin="2"/>
                </Border>
            </Grid>
        </TabItem>

    </TabControl>
</UserControl>
