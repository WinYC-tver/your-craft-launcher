<UserControl x:Class="YCL.Views.ModPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
      xmlns:mods="clr-namespace:YCL.Core.Mods;assembly=YCL.Core"
      mc:Ignorable="d"
      d:DesignHeight="640" d:DesignWidth="900"
      Loaded="ModPage_Loaded">
    <UserControl.Resources>
        <!-- 提示信息 Border 样式：HintMessage 为 null 或空时折叠 -->
        <Style x:Key="HintBorderStyle" TargetType="Border">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding HintMessage}" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding HintMessage}" Value="">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 下载进度区样式：IsDownloading 为 false 时折叠 -->
        <Style x:Key="DownloadProgressStyle" TargetType="StackPanel">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDownloading}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 进度条样式：DownloadPercent = -1 时不定进度 -->
        <Style x:Key="DownloadProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="IsIndeterminate" Value="False"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding DownloadPercent}" Value="-1">
                    <Setter Property="IsIndeterminate" Value="True"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 卡片操作按钮统一样式 -->
        <Style x:Key="CardButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding" Value="10,3"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="MinWidth" Value="56"/>
        </Style>

        <!-- 启用/禁用切换按钮样式：根据 Enabled 状态显示不同文字与颜色 -->
        <Style x:Key="ToggleButtonTextStyle" TargetType="TextBlock">
            <Setter Property="Text" Value="禁用"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Enabled}" Value="True">
                    <Setter Property="Text" Value="启用"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- 顶部：标题 + 版本选择 -->
            <RowDefinition Height="Auto"/>
            <!-- 操作栏 -->
            <RowDefinition Height="Auto"/>
            <!-- 下载进度区 -->
            <RowDefinition Height="Auto"/>
            <!-- 提示信息 -->
            <RowDefinition Height="Auto"/>
            <!-- Tab 内容区 -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ============ 顶部：标题 + 版本选择 ============ -->
        <StackPanel Grid.Row="0" Margin="24,16,24,4">
            <TextBlock Text="模组管理" FontSize="32" FontWeight="SemiBold"/>
            <TextBlock Text="{Binding CurrentGameDirDisplay}" Opacity="0.6" FontSize="13"
                       Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
        </StackPanel>

        <!-- ============ 操作栏：版本选择 + 刷新 ============ -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="24,8,24,8">
            <TextBlock Text="当前版本：" VerticalAlignment="Center" Opacity="0.7" Margin="0,0,4,0"/>
            <ComboBox ItemsSource="{Binding Versions}"
                      SelectedItem="{Binding SelectedVersion, Mode=TwoWay}"
                      DisplayMemberPath="Id"
                      MinWidth="200" Margin="0,0,8,0"/>
            <Button Content="刷新版本" Command="{Binding RefreshVersionsCommand}"
                    Padding="12,4" MinWidth="80" Margin="0,0,8,0"/>
        </StackPanel>

        <!-- ============ 下载进度区 ============ -->
        <StackPanel Grid.Row="2" Margin="24,4,24,8" Style="{StaticResource DownloadProgressStyle}">
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusText}" Opacity="0.8"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Column="1" VerticalAlignment="Center" Opacity="0.7" Margin="12,0,0,0">
                    <Run Text="进度："/>
                    <Run Text="{Binding DownloadPercent, Mode=OneWay, StringFormat=F1}"/>
                    <Run Text="%"/>
                </TextBlock>
            </Grid>
            <ProgressBar Height="6" Margin="0,2,0,8"
                         Style="{StaticResource DownloadProgressBarStyle}"
                         Minimum="0" Maximum="100"
                         Value="{Binding DownloadPercent, Mode=OneWay}"/>
            <Button Content="取消下载" Command="{Binding CancelDownloadCommand}"
                    Padding="12,3" MinWidth="80" HorizontalAlignment="Left"/>
        </StackPanel>

        <!-- ============ 提示信息 ============ -->
        <Border Grid.Row="3" Style="{StaticResource HintBorderStyle}"
                Background="{DynamicResource SystemControlBackgroundAltMediumBrush}"
                CornerRadius="6" Padding="12,8" Margin="24,4,24,8">
            <TextBlock Text="{Binding HintMessage}" TextWrapping="Wrap" Opacity="0.8"/>
        </Border>

        <!-- ============ Tab 内容区 ============ -->
        <TabControl Grid.Row="4" Margin="24,4,24,16" Background="Transparent" Padding="0">
            <!-- Tab 1: 本地模组 -->
            <TabItem Header="本地模组">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 本地模组操作栏 -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="扫描模组" Command="{Binding RefreshLocalModsCommand}"
                                Padding="12,4" MinWidth="80" Margin="0,0,8,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsScanning}" Value="True">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="打开 mods 文件夹" Command="{Binding OpenModsFolderCommand}"
                                Padding="12,4" MinWidth="120" Margin="0,0,8,0"/>
                        <TextBlock VerticalAlignment="Center" Opacity="0.6" Margin="8,0,0,0">
                            <Run Text="共 "/>
                            <Run Text="{Binding LocalMods.Count, Mode=OneWay}"/>
                            <Run Text=" 个模组"/>
                        </TextBlock>
                    </StackPanel>

                    <!-- 本地模组卡片列表 -->
                    <Border Grid.Row="1"
                            Background="{DynamicResource SystemControlBackgroundAltMediumBrush}"
                            CornerRadius="4"
                            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                            BorderThickness="1">
                        <ListBox ItemsSource="{Binding LocalMods}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 Margin="2"
                                 HorizontalContentAlignment="Stretch">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="2"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="2,3" Padding="12,10"
                                            Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                                            CornerRadius="6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- 左侧：图标 -->
                                            <Border Grid.Column="0" Width="40" Height="40"
                                                    Background="{DynamicResource SystemControlBackgroundAltMediumBrush}"
                                                    CornerRadius="4" Margin="0,0,12,0"
                                                    VerticalAlignment="Center">
                                                <Image Source="{Binding LogoPath}" Stretch="Uniform"
                                                       Margin="2"/>
                                            </Border>

                                            <!-- 中间：名称、版本、作者 -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"
                                                               FontSize="14" VerticalAlignment="Center"/>
                                                    <Border Background="#FF6750A4" CornerRadius="3"
                                                            Padding="6,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding LoaderTypeDisplay}"
                                                                   FontSize="11" Foreground="White"/>
                                                    </Border>
                                                    <Border Background="#FF0078D7" CornerRadius="3"
                                                            Padding="6,1" Margin="4,0,0,0" VerticalAlignment="Center">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Enabled}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="启用" FontSize="11" Foreground="White"/>
                                                    </Border>
                                                    <Border Background="#FF888888" CornerRadius="3"
                                                            Padding="6,1" Margin="4,0,0,0" VerticalAlignment="Center">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Enabled}" Value="False">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="禁用" FontSize="11" Foreground="White"/>
                                                    </Border>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0" Opacity="0.6">
                                                    <TextBlock Text="版本：" FontSize="11"/>
                                                    <TextBlock Text="{Binding Version}" FontSize="11" Margin="2,0,8,0"/>
                                                    <TextBlock Text="作者：" FontSize="11"/>
                                                    <TextBlock Text="{Binding AuthorsDisplay}" FontSize="11" Margin="2,0,8,0"/>
                                                    <TextBlock Text="MC：" FontSize="11"/>
                                                    <TextBlock Text="{Binding MinecraftVersion}" FontSize="11" Margin="2,0,0,0"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Description}" Opacity="0.5"
                                                           FontSize="11" Margin="0,2,0,0"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxWidth="500"/>
                                            </StackPanel>

                                            <!-- 右侧：启用开关 + 操作按钮 -->
                                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <Button Style="{StaticResource CardButtonStyle}"
                                                        MinWidth="64"
                                                        Command="{Binding DataContext.ToggleModCommand,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip="切换启用状态">
                                                    <TextBlock Style="{StaticResource ToggleButtonTextStyle}"/>
                                                </Button>
                                                <Button Content="删除"
                                                        Style="{StaticResource CardButtonStyle}"
                                                        Command="{Binding DataContext.DeleteModCommand,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Tab 2: 在线搜索 -->
            <TabItem Header="在线搜索">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 搜索栏 -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBox Text="{Binding SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 MinWidth="300" Margin="0,0,8,0"
                                 KeyDown="SearchBox_KeyDown"/>
                        <ComboBox MinWidth="120" Margin="0,0,8,0"
                                  SelectedValuePath="Tag"
                                  SelectedValue="{Binding SelectedSource, Mode=TwoWay}">
                            <ComboBoxItem Content="全部" Tag="{x:Static mods:ModSource.All}"/>
                            <ComboBoxItem Content="Modrinth" Tag="{x:Static mods:ModSource.Modrinth}"/>
                            <ComboBoxItem Content="CurseForge" Tag="{x:Static mods:ModSource.CurseForge}"/>
                        </ComboBox>
                        <Button Content="搜索" Command="{Binding SearchCommand}"
                                Padding="16,4" MinWidth="80">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSearching}" Value="True">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <TextBlock VerticalAlignment="Center" Opacity="0.6" Margin="8,0,0,0">
                            <Run Text="找到 "/>
                            <Run Text="{Binding SearchResults.Count, Mode=OneWay}"/>
                            <Run Text=" 个结果"/>
                        </TextBlock>
                    </StackPanel>

                    <!-- 搜索结果列表 -->
                    <Border Grid.Row="1"
                            Background="{DynamicResource SystemControlBackgroundAltMediumBrush}"
                            CornerRadius="4"
                            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                            BorderThickness="1">
                        <ListBox ItemsSource="{Binding SearchResults}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 Margin="2"
                                 HorizontalContentAlignment="Stretch">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="2"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="2,3" Padding="12,10"
                                            Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                                            CornerRadius="6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- 图标 -->
                                            <Border Grid.Column="0" Width="40" Height="40"
                                                    Background="{DynamicResource SystemControlBackgroundAltMediumBrush}"
                                                    CornerRadius="4" Margin="0,0,12,0"
                                                    VerticalAlignment="Center">
                                                <Image Source="{Binding LogoUrl}" Stretch="Uniform" Margin="2"/>
                                            </Border>

                                            <!-- 名称、描述、下载量 -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                               FontSize="14" VerticalAlignment="Center"/>
                                                    <Border Background="#FF0078D7" CornerRadius="3"
                                                            Padding="6,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding SourceDisplay}"
                                                                   FontSize="11" Foreground="White"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Description}" Opacity="0.6"
                                                           FontSize="11" Margin="0,4,0,0"
                                                           TextTrimming="CharacterEllipsis" MaxWidth="500"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0" Opacity="0.6">
                                                    <TextBlock Text="下载：" FontSize="11"/>
                                                    <TextBlock Text="{Binding DownloadCountDisplay}" FontSize="11" Margin="2,0,8,0"/>
                                                    <TextBlock Text="作者：" FontSize="11"/>
                                                    <TextBlock Text="{Binding Author}" FontSize="11" Margin="2,0,0,0"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- 下载按钮 -->
                                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <Button Content="下载"
                                                        Style="{StaticResource CardButtonStyle}"
                                                        Command="{Binding DataContext.DownloadModCommand,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
