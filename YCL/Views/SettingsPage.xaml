<UserControl x:Class="YCL.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
      xmlns:models="clr-namespace:YCL.Models;assembly=YCL.Models"
      mc:Ignorable="d"
      d:DesignHeight="900" d:DesignWidth="800">
    <!-- 设置页内容较多，用 ScrollViewer 包裹方便滚动 -->
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,16,24,24">

            <!-- 页面大标题 -->
            <TextBlock Text="设置" FontSize="32" FontWeight="SemiBold" Margin="0,0,0,16"/>

            <!-- ================================================================ -->
            <!-- 启动设置 -->
            <!-- ================================================================ -->
            <TextBlock Text="启动设置" FontSize="20" FontWeight="SemiBold"
                       Margin="0,8,0,8" Opacity="0.8"/>

            <!-- Java 路径 -->
            <ui:SettingsCard Header="Java 路径" Description="启动游戏使用的 Java 运行时（javaw.exe）">
                <ui:SettingsCard.HeaderIcon>
                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.DeveloperTools}"/>
                </ui:SettingsCard.HeaderIcon>
                <StackPanel Orientation="Horizontal">
                    <TextBox Text="{Binding JavaPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             MinWidth="280" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <Button Content="浏览" Command="{Binding BrowseJavaPathCommand}"
                            Padding="12,4" Margin="0,0,8,0"/>
                    <Button Content="检测 Java" Command="{Binding GoToJavaPageCommand}"
                            Padding="12,4"/>
                </StackPanel>
            </ui:SettingsCard>

            <!-- 最大内存 -->
            <ui:SettingsCard Header="最大内存 (-Xmx)" Description="Java 虚拟机最大堆内存，单位 MB（建议 2048~4096）">
                <ui:SettingsCard.HeaderIcon>
                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.SDCard}"/>
                </ui:SettingsCard.HeaderIcon>
                <StackPanel Orientation="Horizontal">
                    <TextBox Text="{Binding MaxMemory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             MinWidth="100" VerticalAlignment="Center"/>
                    <TextBlock Text="MB" VerticalAlignment="Center" Margin="8,0,0,0" Opacity="0.6"/>
                </StackPanel>
            </ui:SettingsCard>

            <!-- 初始内存 -->
            <ui:SettingsCard Header="初始内存 (-Xms)" Description="Java 虚拟机初始堆内存，单位 MB（建议 512~1024）">
                <ui:SettingsCard.HeaderIcon>
                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.SDCard}"/>
                </ui:SettingsCard.HeaderIcon>
                <StackPanel Orientation="Horizontal">
                    <TextBox Text="{Binding MinMemory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             MinWidth="100" VerticalAlignment="Center"/>
                    <TextBlock Text="MB" VerticalAlignment="Center" Margin="8,0,0,0" Opacity="0.6"/>
                </StackPanel>
            </ui:SettingsCard>

            <!-- 游戏窗口大小 -->
            <ui:SettingsCard Header="游戏窗口大小" Description="启动时游戏窗口的宽度和高度（像素）">
                <ui:SettingsCard.HeaderIcon>
                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.ViewAll}"/>
                </ui:SettingsCard.HeaderIcon>
                <StackPanel Orientation="Horizontal">
                    <TextBox Text="{Binding WindowWidth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             MinWidth="70" VerticalAlignment="Center"/>
                    <TextBlock Text=" × " VerticalAlignment="Center" Margin="4,0"/>
                    <TextBox Text="{Binding WindowHeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             MinWidth="70" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="像素" VerticalAlignment="Center" Opacity="0.6"/>
                </StackPanel>
            </ui:SettingsCard>

            <!-- 全屏启动 -->
            <ui:SettingsCard Header="全屏启动" Description="启动游戏时自动进入全屏模式（--fullscreen 参数）">
                <ui:SettingsCard.HeaderIcon>
                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.FitPage}"/>
                </ui:SettingsCard.HeaderIcon>
                <ui:ToggleSwitch IsOn="{Binding FullscreenOnLaunch, Mode=TwoWay}"/>
            </ui:SettingsCard>

            <!-- 启动后关闭启动器 -->
            <ui:SettingsCard Header="启动后关闭启动器" Description="游戏成功启动后自动关闭启动器窗口，节省内存">
                <ui:SettingsCard.HeaderIcon>
                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.ChromeBackToWindow}"/>
                </ui:SettingsCard.HeaderIcon>
                <ui:ToggleSwitch IsOn="{Binding CloseAfterLaunch, Mode=TwoWay}"/>
            </ui:SettingsCard>

            <!-- 高级 JVM 参数 -->
            <ui:SettingsCard Header="高级 JVM 参数" Description="用户自定义追加的 JVM 参数，多个参数用空格分隔（如 -XX:+UseG1GC -XX:MaxGCPauseMillis=50）">
                <ui:SettingsCard.HeaderIcon>
                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Settings}"/>
                </ui:SettingsCard.HeaderIcon>
                <TextBox Text="{Binding ExtraJvmArgs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         MinWidth="300" AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalContentAlignment="Center" MaxLines="3"/>
            </ui:SettingsCard>

            <!-- ================================================================ -->
            <!-- 游戏设置 -->
            <!-- ================================================================ -->
            <TextBlock Text="游戏设置" FontSize="20" FontWeight="SemiBold"
                       Margin="0,24,0,8" Opacity="0.8"/>

            <!-- 游戏目录 -->
            <ui:SettingsCard Header="游戏目录 (.minecraft)" Description="Minecraft 游戏所在的 .minecraft 目录路径">
                <ui:SettingsCard.HeaderIcon>
                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Folder}"/>
                </ui:SettingsCard.HeaderIcon>
                <StackPanel Orientation="Horizontal">
                    <TextBox Text="{Binding MinecraftPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             MinWidth="280" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <Button Content="浏览" Command="{Binding BrowseMinecraftPathCommand}"
                            Padding="12,4"/>
                </StackPanel>
            </ui:SettingsCard>

            <!-- 版本隔离 -->
            <ui:SettingsCard Header="版本隔离" Description="启用后每个版本拥有独立的 mods/saves/configs 目录（通过 --gameDir 实现）">
                <ui:SettingsCard.HeaderIcon>
                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Split20}"/>
                </ui:SettingsCard.HeaderIcon>
                <ui:ToggleSwitch IsOn="{Binding EnableVersionIsolation, Mode=TwoWay}"/>
            </ui:SettingsCard>

            <!-- 启动前自动清理 -->
            <ui:SettingsCard Header="启动前自动清理" Description="启动游戏前清理旧的 natives 临时文件（释放磁盘空间）">
                <ui:SettingsCard.HeaderIcon>
                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Delete}"/>
                </ui:SettingsCard.HeaderIcon>
                <ui:ToggleSwitch IsOn="{Binding CleanBeforeLaunch, Mode=TwoWay}"/>
            </ui:SettingsCard>

            <!-- ================================================================ -->
            <!-- 下载设置 -->
            <!-- ================================================================ -->
            <TextBlock Text="下载设置" FontSize="20" FontWeight="SemiBold"
                       Margin="0,24,0,8" Opacity="0.8"/>

            <!-- 下载源 -->
            <ui:SettingsCard Header="下载源" Description="选择 Minecraft 文件下载源（国内镜像可加速下载）">
                <ui:SettingsCard.HeaderIcon>
                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Globe}"/>
                </ui:SettingsCard.HeaderIcon>
                <ComboBox SelectedValue="{Binding SelectedDownloadSource, Mode=TwoWay}"
                          SelectedValuePath="Tag"
                          MinWidth="160">
                    <ComboBoxItem Content="官方源" Tag="{x:Static models:DownloadSource.Official}"/>
                    <ComboBoxItem Content="BMCLAPI 镜像" Tag="{x:Static models:DownloadSource.BMCLAPI}"/>
                    <ComboBoxItem Content="MCBBS 镜像" Tag="{x:Static models:DownloadSource.MCBBS}"/>
                </ComboBox>
            </ui:SettingsCard>

            <!-- 下载线程数 -->
            <ui:SettingsCard Header="下载线程数" Description="同时下载的文件数（1~32，建议 4~8）">
                <ui:SettingsCard.HeaderIcon>
                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Processing}"/>
                </ui:SettingsCard.HeaderIcon>
                <TextBox Text="{Binding DownloadThreads, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         MinWidth="80" VerticalAlignment="Center"/>
            </ui:SettingsCard>

            <!-- 重试次数 -->
            <ui:SettingsCard Header="重试次数" Description="下载失败时的自动重试次数（0~10）">
                <ui:SettingsCard.HeaderIcon>
                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.RepeatAll}"/>
                </ui:SettingsCard.HeaderIcon>
                <TextBox Text="{Binding RetryCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         MinWidth="80" VerticalAlignment="Center"/>
            </ui:SettingsCard>

            <!-- CurseForge API Key -->
            <ui:SettingsCard Header="CurseForge API Key" Description="可选，用于 CurseForge 模组搜索。在 https://console.curseforge.com 获取">
                <ui:SettingsCard.HeaderIcon>
                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Page}"/>
                </ui:SettingsCard.HeaderIcon>
                <TextBox Text="{Binding CurseForgeApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         MinWidth="280" VerticalAlignment="Center"/>
            </ui:SettingsCard>

            <!-- ================================================================ -->
            <!-- 系统设置 -->
            <!-- ================================================================ -->
            <TextBlock Text="系统设置" FontSize="20" FontWeight="SemiBold"
                       Margin="0,24,0,8" Opacity="0.8"/>

            <!-- 日志路径 -->
            <ui:SettingsCard Header="日志路径" Description="启动器日志文件的保存位置（按日期分文件）">
                <ui:SettingsCard.HeaderIcon>
                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Page}"/>
                </ui:SettingsCard.HeaderIcon>
                <StackPanel Orientation="Horizontal">
                    <TextBox Text="{Binding LogPath, Mode=OneWay}" IsReadOnly="True"
                             MinWidth="280" Margin="0,0,8,0" VerticalAlignment="Center" Opacity="0.7"/>
                    <Button Content="打开日志文件夹" Command="{Binding OpenLogFolderCommand}"
                            Padding="12,4"/>
                </StackPanel>
            </ui:SettingsCard>

            <!-- 开机自启 -->
            <ui:SettingsCard Header="开机自启" Description="开机时自动启动 YCL 启动器（写入注册表）">
                <ui:SettingsCard.HeaderIcon>
                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.PowerButton}"/>
                </ui:SettingsCard.HeaderIcon>
                <ui:ToggleSwitch IsOn="{Binding LaunchOnStartup, Mode=TwoWay}"/>
            </ui:SettingsCard>

            <!-- 启动时检查更新 -->
            <ui:SettingsCard Header="启动时检查更新" Description="启动器启动时自动检查是否有新版本">
                <ui:SettingsCard.HeaderIcon>
                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Sync}"/>
                </ui:SettingsCard.HeaderIcon>
                <ui:ToggleSwitch IsOn="{Binding CheckUpdateOnStartup, Mode=TwoWay}"/>
            </ui:SettingsCard>

            <!-- 启动器更新仓库 -->
            <ui:SettingsCard Header="启动器更新仓库" Description="GitHub 仓库地址（格式 owner/repo，用于检查更新）">
                <ui:SettingsCard.HeaderIcon>
                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.World}"/>
                </ui:SettingsCard.HeaderIcon>
                <StackPanel Orientation="Horizontal">
                    <TextBox Text="{Binding UpdateRepo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             MinWidth="200" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Button Content="立即检查" Command="{Binding CheckUpdateNowCommand}"
                            Padding="12,4">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCheckingUpdate}" Value="True">
                                        <Setter Property="IsEnabled" Value="False"/>
                                        <Setter Property="Content" Value="检查中..."/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </ui:SettingsCard>

            <!-- 更新检查结果显示（非空时显示） -->
            <Border Background="{DynamicResource SystemControlBackgroundAltMediumBrush}"
                    CornerRadius="6" Padding="12,8" Margin="0,4,0,0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding UpdateCheckResult}" Value="">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding UpdateCheckResult}" Opacity="0.8" TextWrapping="Wrap"/>
            </Border>

            <!-- ================================================================ -->
            <!-- 外观设置（主题） -->
            <!-- ================================================================ -->
            <TextBlock Text="外观" FontSize="20" FontWeight="SemiBold"
                       Margin="0,24,0,8" Opacity="0.8"/>

            <!-- 主题模式 -->
            <ui:SettingsCard Header="主题模式" Description="选择启动器的亮色 / 暗色 / 跟随系统主题">
                <ui:SettingsCard.HeaderIcon>
                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Color}"/>
                </ui:SettingsCard.HeaderIcon>
                <ComboBox SelectedValue="{Binding SelectedThemeMode, Mode=TwoWay}"
                          SelectedValuePath="Tag"
                          MinWidth="160">
                    <ComboBoxItem Content="跟随系统" Tag="{x:Static models:ThemeMode.Default}"/>
                    <ComboBoxItem Content="亮色" Tag="{x:Static models:ThemeMode.Light}"/>
                    <ComboBoxItem Content="暗色" Tag="{x:Static models:ThemeMode.Dark}"/>
                </ComboBox>
            </ui:SettingsCard>

            <!-- 跟随系统强调色 -->
            <ui:SettingsCard Header="跟随系统强调色"
                             Description="开启后使用 Windows 系统强调色，关闭后可选择自定义颜色">
                <ui:SettingsCard.HeaderIcon>
                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Highlight}"/>
                </ui:SettingsCard.HeaderIcon>
                <ui:ToggleSwitch IsOn="{Binding UseSystemAccentColor, Mode=TwoWay}"/>
            </ui:SettingsCard>

            <!-- 自定义强调色 -->
            <ui:SettingsCard Header="自定义强调色" Description="点击下方色块选择喜欢的强调色">
                <ui:SettingsCard.HeaderIcon>
                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.PenPalette}"/>
                </ui:SettingsCard.HeaderIcon>
                <ItemsControl ItemsSource="{Binding PresetAccentColors}"
                              IsEnabled="{Binding IsCustomAccentColorEnabled}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Width="40" Height="40" Margin="4"
                                    Command="{Binding DataContext.SelectAccentColorCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    ToolTip="{Binding}">
                                <Button.Background>
                                    <SolidColorBrush Color="{Binding}"/>
                                </Button.Background>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ui:SettingsCard>

        </StackPanel>
    </ScrollViewer>
</UserControl>
