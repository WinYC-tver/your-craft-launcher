<UserControl x:Class="YCL.Views.ResourcePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
      xmlns:res="clr-namespace:YCL.Core.Resources;assembly=YCL.Core"
      xmlns:mods="clr-namespace:YCL.Core.Mods;assembly=YCL.Core"
      mc:Ignorable="d"
      d:DesignHeight="640" d:DesignWidth="900"
      Loaded="ResourcePage_Loaded">
    <UserControl.Resources>
        <!-- 提示信息 Border 样式 -->
        <Style x:Key="HintBorderStyle" TargetType="Border">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding HintMessage}" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding HintMessage}" Value="">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 安装进度区样式 -->
        <Style x:Key="InstallProgressStyle" TargetType="StackPanel">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsInstalling}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 进度条样式 -->
        <Style x:Key="ProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="IsIndeterminate" Value="False"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding ProgressPercent}" Value="-1">
                    <Setter Property="IsIndeterminate" Value="True"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 卡片操作按钮样式 -->
        <Style x:Key="CardButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding" Value="10,3"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="MinWidth" Value="56"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- 顶部：标题 -->
            <RowDefinition Height="Auto"/>
            <!-- 操作栏：版本选择 + 资源类型 + 从本地安装 -->
            <RowDefinition Height="Auto"/>
            <!-- 搜索栏 -->
            <RowDefinition Height="Auto"/>
            <!-- 安装进度区 -->
            <RowDefinition Height="Auto"/>
            <!-- 提示信息 -->
            <RowDefinition Height="Auto"/>
            <!-- 结果列表 -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ============ 顶部：标题 ============ -->
        <StackPanel Grid.Row="0" Margin="24,16,24,4">
            <TextBlock Text="资源中心" FontSize="32" FontWeight="SemiBold"/>
            <TextBlock Text="{Binding CurrentGameDirDisplay}" Opacity="0.6" FontSize="13"
                       Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
        </StackPanel>

        <!-- ============ 操作栏 ============ -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="24,8,24,8">
            <TextBlock Text="当前版本：" VerticalAlignment="Center" Opacity="0.7" Margin="0,0,4,0"/>
            <ComboBox ItemsSource="{Binding Versions}"
                      SelectedItem="{Binding SelectedVersion, Mode=TwoWay}"
                      DisplayMemberPath="Id"
                      MinWidth="200" Margin="0,0,8,0"/>
            <TextBlock Text="资源类型：" VerticalAlignment="Center" Opacity="0.7" Margin="0,0,4,0"/>
            <ComboBox MinWidth="120" Margin="0,0,8,0"
                      SelectedValuePath="Tag"
                      SelectedValue="{Binding SelectedResourceType, Mode=TwoWay}">
                <ComboBoxItem Content="资源包" Tag="{x:Static res:ResourceType.ResourcePack}"/>
                <ComboBoxItem Content="光影包" Tag="{x:Static res:ResourceType.ShaderPack}"/>
                <ComboBoxItem Content="地图" Tag="{x:Static res:ResourceType.World}"/>
            </ComboBox>
            <Button Content="从本地安装整合包" Command="{Binding InstallModpackFromFileCommand}"
                    Padding="12,4" MinWidth="140" Margin="0,0,8,0"
                    ToolTip="选择本地整合包 zip 文件安装"/>
        </StackPanel>

        <!-- ============ 搜索栏 ============ -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="24,0,24,8">
            <TextBox Text="{Binding SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     MinWidth="300" Margin="0,0,8,0"
                     KeyDown="SearchBox_KeyDown"/>
            <ComboBox MinWidth="120" Margin="0,0,8,0"
                      SelectedValuePath="Tag"
                      SelectedValue="{Binding SelectedSource, Mode=TwoWay}">
                <ComboBoxItem Content="全部" Tag="{x:Static mods:ModSource.All}"/>
                <ComboBoxItem Content="Modrinth" Tag="{x:Static mods:ModSource.Modrinth}"/>
                <ComboBoxItem Content="CurseForge" Tag="{x:Static mods:ModSource.CurseForge}"/>
            </ComboBox>
            <Button Content="搜索" Command="{Binding SearchCommand}"
                    Padding="16,4" MinWidth="80">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSearching}" Value="True">
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <TextBlock VerticalAlignment="Center" Opacity="0.6" Margin="8,0,0,0">
                <Run Text="找到 "/>
                <Run Text="{Binding SearchResults.Count, Mode=OneWay}"/>
                <Run Text=" 个结果"/>
            </TextBlock>
        </StackPanel>

        <!-- ============ 安装进度区 ============ -->
        <StackPanel Grid.Row="3" Margin="24,4,24,8" Style="{StaticResource InstallProgressStyle}">
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusText}" Opacity="0.8"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Column="1" VerticalAlignment="Center" Opacity="0.7" Margin="12,0,0,0">
                    <Run Text="进度："/>
                    <Run Text="{Binding ProgressPercent, Mode=OneWay, StringFormat=F1}"/>
                    <Run Text="%"/>
                </TextBlock>
            </Grid>
            <ProgressBar Height="6" Margin="0,2,0,8"
                         Style="{StaticResource ProgressBarStyle}"
                         Minimum="0" Maximum="100"
                         Value="{Binding ProgressPercent, Mode=OneWay}"/>
            <Button Content="取消" Command="{Binding CancelInstallCommand}"
                    Padding="12,3" MinWidth="80" HorizontalAlignment="Left"/>
        </StackPanel>

        <!-- ============ 提示信息 ============ -->
        <Border Grid.Row="4" Style="{StaticResource HintBorderStyle}"
                Background="{DynamicResource SystemControlBackgroundAltMediumBrush}"
                CornerRadius="6" Padding="12,8" Margin="24,4,24,8">
            <TextBlock Text="{Binding HintMessage}" TextWrapping="Wrap" Opacity="0.8"/>
        </Border>

        <!-- ============ 搜索结果列表 ============ -->
        <Grid Grid.Row="5" Margin="24,4,24,16">
            <Border Background="{DynamicResource SystemControlBackgroundAltMediumBrush}"
                    CornerRadius="4"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                    BorderThickness="1">
                <ListBox ItemsSource="{Binding SearchResults}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         Margin="2"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="2"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="2,3" Padding="12,10"
                                    Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                                    CornerRadius="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 图标 -->
                                    <Border Grid.Column="0" Width="40" Height="40"
                                            Background="{DynamicResource SystemControlBackgroundAltMediumBrush}"
                                            CornerRadius="4" Margin="0,0,12,0"
                                            VerticalAlignment="Center">
                                        <Image Source="{Binding LogoUrl}" Stretch="Uniform" Margin="2"/>
                                    </Border>

                                    <!-- 名称、描述 -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                       FontSize="14" VerticalAlignment="Center"/>
                                            <Border Background="#FF0078D7" CornerRadius="3"
                                                    Padding="6,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding SourceDisplay}"
                                                           FontSize="11" Foreground="White"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Description}" Opacity="0.6"
                                                   FontSize="11" Margin="0,4,0,0"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="500"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0" Opacity="0.6">
                                            <TextBlock Text="下载：" FontSize="11"/>
                                            <TextBlock Text="{Binding DownloadCountDisplay}" FontSize="11" Margin="2,0,8,0"/>
                                            <TextBlock Text="作者：" FontSize="11"/>
                                            <TextBlock Text="{Binding Author}" FontSize="11" Margin="2,0,0,0"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- 下载按钮 -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <Button Content="下载"
                                                Style="{StaticResource CardButtonStyle}"
                                                Command="{Binding DataContext.DownloadCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </Grid>
    </Grid>
</UserControl>
