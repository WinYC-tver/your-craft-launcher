<UserControl x:Class="YCL.Views.AccountPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
      xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
      mc:Ignorable="d"
      d:DesignHeight="640" d:DesignWidth="900"
      Loaded="AccountPage_Loaded">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,16,24,24">

            <!-- 页面标题 + 添加按钮 -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="账户管理" FontSize="32" FontWeight="SemiBold"/>
                <Button Grid.Column="1" Content="+ 添加账户" Command="{Binding ShowAddPanelCommand}"
                        MinWidth="120" MinHeight="36"/>
            </Grid>

            <!-- ============ 3D 皮肤预览区（Webview2） ============ -->
            <!-- 注意：Webview2 预留接口。若运行时未安装 Webview2 Runtime，
                 下方 SkinPreviewWebView 会被隐藏并显示降级文字提示。 -->
            <Border Background="{DynamicResource SystemControlBackgroundAltMediumBrush}"
                    CornerRadius="8" Padding="12" Margin="0,0,0,16"
                    HorizontalAlignment="Left">
                <StackPanel>
                    <TextBlock Text="3D 皮肤预览" FontSize="14" FontWeight="SemiBold"
                               Margin="0,0,0,8" HorizontalAlignment="Center"/>
                    <!-- Webview2 控件：渲染 three.js 3D 皮肤模型，大小 240x320 -->
                    <wv2:WebView2 x:Name="SkinPreviewWebView"
                                  Width="240" Height="320"
                                  Visibility="Collapsed"/>
                    <!-- 降级提示：Webview2 初始化失败时显示 -->
                    <Border x:Name="SkinPreviewFallback"
                            Width="240" Height="320"
                            Background="#22000000"
                            CornerRadius="4"
                            Visibility="Visible">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="3D 预览不可用" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <TextBlock Text="未检测到 Webview2 运行时&#x0a;请安装后重启应用"
                                       FontSize="11" Opacity="0.6" TextAlignment="Center"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ============ 添加账户面板 ============ -->
            <Border Background="{DynamicResource SystemControlBackgroundAltMediumBrush}"
                    CornerRadius="8" Padding="16" Margin="0,0,0,16"
                    Visibility="{Binding IsAddPanelVisible, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="添加账户" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <!-- 账户类型选择 -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="类型：" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox SelectedIndex="{Binding SelectedAddTypeIndex, Mode=TwoWay}" MinWidth="120">
                            <ComboBoxItem Content="离线账户"/>
                            <ComboBoxItem Content="微软账户"/>
                            <ComboBoxItem Content="外置登录"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- 离线账户输入区 -->
                    <StackPanel Margin="0,0,0,8"
                                Visibility="{Binding IsOfflineSelected, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="玩家名：" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding OfflineUsername, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 MinHeight="32" MinWidth="280" MaxWidth="400" HorizontalAlignment="Left"
                                 VerticalContentAlignment="Center" Padding="8,4"/>
                    </StackPanel>

                    <!-- 微软账户提示 -->
                    <StackPanel Margin="0,0,0,8"
                                Visibility="{Binding IsMicrosoftSelected, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="点击下方“确认”开始微软账户登录。系统会显示一个代码，请用浏览器访问微软验证页面并输入代码完成登录。"
                                   Opacity="0.7" TextWrapping="Wrap" MaxWidth="600"/>
                    </StackPanel>

                    <!-- 外置登录输入区 -->
                    <StackPanel Margin="0,0,0,8"
                                Visibility="{Binding IsYggdrasilSelected, Converter={StaticResource BoolToVis}}">
                        <StackPanel Margin="0,0,0,8">
                            <TextBlock Text="认证服务器地址：" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding YggdrasilServerUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     MinHeight="32" MinWidth="400" HorizontalAlignment="Left"
                                     VerticalContentAlignment="Center" Padding="8,4"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,8">
                            <TextBlock Text="用户名：" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding YggdrasilUsername, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     MinHeight="32" MinWidth="280" HorizontalAlignment="Left"
                                     VerticalContentAlignment="Center" Padding="8,4"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="密码：" Margin="0,0,0,4"/>
                            <PasswordBox x:Name="YggdrasilPasswordBox" MinHeight="32" MinWidth="280"
                                         HorizontalAlignment="Left" VerticalContentAlignment="Center" Padding="8,4"
                                         PasswordChanged="YggdrasilPasswordBox_PasswordChanged"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- 提示信息 -->
                    <TextBlock Text="{Binding AddMessage}" Foreground="#FFD6454A" Margin="0,4,0,8"
                               TextWrapping="Wrap"/>

                    <!-- 微软登录进度区 -->
                    <Border Background="#FF1E1E1E" CornerRadius="4" Padding="12" Margin="0,4,0,8"
                            Visibility="{Binding IsMicrosoftLoginVisible, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="{Binding MsProgressMessage}" Foreground="#FFD4D4D4"
                                       TextWrapping="Wrap" Margin="0,0,0,8"/>
                            <!-- 用户代码与验证网址 -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="代码：" Foreground="#FFD4D4D4" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding MsUserCode}" Foreground="#FF4FC3F7" FontSize="20"
                                           FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="网址：" Foreground="#FFD4D4D4" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding MsVerificationUri}" Foreground="#FF4FC3F7" VerticalAlignment="Center"/>
                            </StackPanel>
                            <!-- 打开浏览器按钮 -->
                            <Button Content="打开浏览器" Command="{Binding OpenBrowserCommand}"
                                    Margin="0,4,0,0" Padding="16,4" HorizontalAlignment="Left"
                                    Visibility="{Binding ShowOpenBrowserButton, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                    </Border>

                    <!-- 确认 / 取消按钮 -->
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="确认" Command="{Binding ConfirmAddCommand}"
                                MinWidth="80" MinHeight="32" Margin="0,0,12,0"/>
                        <Button Content="取消" Command="{Binding CancelAddCommand}"
                                MinWidth="80" MinHeight="32"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ============ 账户列表 ============ -->
            <ItemsControl ItemsSource="{Binding Accounts}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource SystemControlBackgroundAltMediumBrush}"
                                CornerRadius="8" Padding="16,12" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- 头像 -->
                                <Border Grid.Column="0" Width="48" Height="48" CornerRadius="4" ClipToBounds="True">
                                    <Border.Background>
                                        <SolidColorBrush Color="#FFCCCCCC"/>
                                    </Border.Background>
                                    <Image Source="{Binding Avatar}" Stretch="Fill"/>
                                </Border>

                                <!-- 用户名 + 类型 -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Username}" FontWeight="SemiBold" FontSize="15"
                                                   VerticalAlignment="Center"/>
                                        <!-- 当前账户标记 -->
                                        <TextBlock Text="● 当前" Foreground="#FF4CAF50" FontSize="11" Margin="8,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding IsCurrent, Converter={StaticResource BoolToVis}}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                        <Border Background="#33808080" CornerRadius="3" Padding="6,1" Margin="0,0,8,0">
                                            <TextBlock Text="{Binding TypeText}" FontSize="11" Opacity="0.8"/>
                                        </Border>
                                        <TextBlock Text="{Binding Uuid}" FontSize="11" Opacity="0.5"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="280"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- 操作按钮 -->
                                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="设为当前" Command="{Binding RelativeSource={RelativeSource AncestorType=ItemsControl},
                                                                          Path=DataContext.SetCurrentCommand}"
                                            CommandParameter="{Binding AccountId}"
                                            Padding="10,4" Margin="0,0,6,0" FontSize="12"/>
                                    <Button Content="刷新" Command="{Binding RelativeSource={RelativeSource AncestorType=ItemsControl},
                                                                          Path=DataContext.RefreshCommand}"
                                            CommandParameter="{Binding AccountId}"
                                            Padding="10,4" Margin="0,0,6,0" FontSize="12"/>
                                    <Button Content="删除" Command="{Binding RelativeSource={RelativeSource AncestorType=ItemsControl},
                                                                          Path=DataContext.RemoveCommand}"
                                            CommandParameter="{Binding AccountId}"
                                            Padding="10,4" FontSize="12"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- 空列表提示 -->
            <TextBlock Text="还没有账户，点击上方“+ 添加账户”按钮创建一个。"
                       Opacity="0.5" HorizontalAlignment="Center" Margin="0,24,0,0"
                       Visibility="{Binding HasNoAccounts, Converter={StaticResource BoolToVis}}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
