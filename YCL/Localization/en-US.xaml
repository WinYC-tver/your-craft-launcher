<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">
    <!-- ====== App Title ====== -->
    <sys:String x:Key="App_Title">YCL Launcher</sys:String>

    <!-- ====== Navigation ====== -->
    <sys:String x:Key="Nav_Launch">Launch</sys:String>
    <sys:String x:Key="Nav_Download">Download</sys:String>
    <sys:String x:Key="Nav_News">News</sys:String>
    <sys:String x:Key="Nav_Functions">Functions</sys:String>
    <sys:String x:Key="Nav_Settings">Settings</sys:String>
    <sys:String x:Key="Nav_Multiplayer">Multiplayer</sys:String>
    <sys:String x:Key="Nav_Instance">Instances</sys:String>
    <sys:String x:Key="Nav_Java">Java</sys:String>
    <sys:String x:Key="Nav_Account">Account</sys:String>
    <sys:String x:Key="Nav_Saves">Saves</sys:String>
    <sys:String x:Key="Nav_Screenshots">Screenshots</sys:String>

    <!-- ====== Launch Page ====== -->
    <sys:String x:Key="Launch_Button">Launch Game</sys:String>
    <sys:String x:Key="Launch_Status_Ready">Ready</sys:String>
    <sys:String x:Key="Launch_Status_Launching">Launching...</sys:String>
    <sys:String x:Key="Launch_Status_Running">Running</sys:String>

    <!-- ====== Settings Categories ====== -->
    <sys:String x:Key="Settings_LaunchManage">Launch &amp; Manage</sys:String>
    <sys:String x:Key="Settings_GameSettings">Game Settings</sys:String>
    <sys:String x:Key="Settings_Personalize">Personalize</sys:String>
    <sys:String x:Key="Settings_Download">Download</sys:String>
    <sys:String x:Key="Settings_Advanced">Advanced</sys:String>
    <sys:String x:Key="Settings_About">About</sys:String>
    <sys:String x:Key="Settings_Search_Placeholder">Search settings...</sys:String>

    <!-- ====== Common Buttons ====== -->
    <sys:String x:Key="Common_OK">OK</sys:String>
    <sys:String x:Key="Common_Cancel">Cancel</sys:String>
    <sys:String x:Key="Common_Save">Save</sys:String>
    <sys:String x:Key="Common_Refresh">Refresh</sys:String>
    <sys:String x:Key="Common_Back">Back</sys:String>

    <!-- ====== Account Page ====== -->
    <sys:String x:Key="Account_NoAccount">No account selected</sys:String>
    <sys:String x:Key="Account_SwitchAccount">Switch Account</sys:String>

    <!-- ====== Java Page ====== -->
    <sys:String x:Key="Java_AutoSelect">Auto Select</sys:String>
    <sys:String x:Key="Java_InstallOnline">Install Java Online</sys:String>

    <!-- ====== News Page ====== -->
    <sys:String x:Key="News_NoHomepage">You haven't configured a homepage yet. Please set one in Settings &gt; Personalize</sys:String>
    <sys:String x:Key="News_GoToSettings">Go to Settings</sys:String>

    <!-- ====== Download Page ====== -->
    <sys:String x:Key="Download_SearchPlaceholder">Search mods, modpacks, resource packs...</sys:String>
    <sys:String x:Key="Download_Category_Game">Game</sys:String>
    <sys:String x:Key="Download_Category_Resource">Resource</sys:String>
    <sys:String x:Key="Download_Category_Favorites">Favorites</sys:String>
    <sys:String x:Key="Download_GetNow">Get Now</sys:String>

    <!-- ====== Crash Report Window ====== -->
    <sys:String x:Key="Crash_Title">Game Crashed</sys:String>
    <sys:String x:Key="Crash_Close">Close</sys:String>
    <sys:String x:Key="Crash_OpenFolder">Open Report Folder</sys:String>
    <sys:String x:Key="Crash_CopyPath">Copy Path</sys:String>
</ResourceDictionary>
